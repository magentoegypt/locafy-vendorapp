<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/card_bg">

    <!-- Image Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="16dp">

        <TextView
            android:id="@+id/imageLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/image"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="90dp"
            android:layout_height="90dp"
            android:scaleType="centerCrop"
            android:src="@drawable/placeholder" />

    </LinearLayout>

    <!-- Name Section -->
    <LinearLayout
        android:id="@+id/nameSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/nameLabel"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/product_name"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/nameTxtField"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/edittext_bg"
            android:padding="4dp" />
    </LinearLayout>

    <!-- SKU Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/skuLabel"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/SKU"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/skuTxtField"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/edittext_bg"
            android:padding="4dp"
            android:visibility="visible" />

    </LinearLayout>

    <!-- Price Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/priceLabel"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/price"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/priceTxtField"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/edittext_bg"
            android:inputType="numberDecimal"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Quantity Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/quantityLabel"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/qty"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/quantityTxtField"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/edittext_bg"
            android:inputType="number"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Weight Section -->
    <LinearLayout
        android:id="@+id/weightSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/weightLabel"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/weighttag"
            android:textSize="16sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/weightTxtField"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/edittext_bg"
            android:inputType="numberDecimal"
            android:padding="4dp" />
    </LinearLayout>

    <!-- Status Section -->
    <LinearLayout
        android:id="@+id/statusSection"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/statusLabel"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="@string/status"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/statusValue"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/enabled"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/selectButton"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="8dp"
            android:text="@string/select"
            android:gravity="center_vertical"
            android:textColor="@color/blue" />
    </LinearLayout>

    <!-- Attributes Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/attributesLabel"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="@string/attributes"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/attributeLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Separator -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#AAAAAA" />

</LinearLayout>