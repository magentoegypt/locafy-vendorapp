<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.cardview.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:id="@+id/MultiVendor_resourcesection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:background="@color/white"
        card_view:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/MultiVendor_Resource"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/AppTheme">

                <TextView
                    android:id="@+id/MultiVendor_Resource_Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:text="@string/vendorresources"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="10dp">

                <TextView
                    android:id="@+id/prodLimitText"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/productlimit"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/MultiVendor_ProductLimit"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/MultiVendor_ProductLimit"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="start|center"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text=""
                    app:layout_constraintEnd_toStartOf="@id/remainingProdText"
                    app:layout_constraintStart_toEndOf="@id/prodLimitText"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/remainingProdText"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="@string/remainingprod"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toStartOf="@id/MultiVendor_RemainingProd"
                    app:layout_constraintStart_toEndOf="@id/MultiVendor_ProductLimit"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/MultiVendor_RemainingProd"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:gravity="start|center"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text=""
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/remainingProdText"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <androidx.cardview.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
        android:id="@+id/MultiVendor_planhistorysection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/MultiVendor_resourcesection"
        android:layout_margin="2dp"
        android:background="@color/white"
        card_view:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/MultiVendor_RunningPlan"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:background="@color/AppTheme">

                <TextView
                    android:id="@+id/MultiVendor_RunningPlan_Text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:text="@string/subscriptionhistory"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_margin="10dp"
                android:background="@color/gray_light">

                <TextView
                    android:id="@+id/MultiVendor_ItemCount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_marginStart="20dp"
                    android:textColor="@color/black"
                    android:textSize="12sp"
                    android:textStyle="bold" />

            </RelativeLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/MultiVendor_SubscriptionHistoryListView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                app:spanCount="1" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>