<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        android:background="@color/white"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_prod_name_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/Product"
                    android:textColor="@color/black"

                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_prod_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_prod_sku_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/prod_SKU"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_prod_sku"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_prod_price_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/price"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_prod_price"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/MultiVendor_invoiced_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/qty_ordered"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_prod_qty_ordered"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/MultiVendor_Shipped_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_prod_qty_shipped_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/qty_shipped"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_prod_qty_shipped"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_prod_qty_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/QuantitytoInvoice"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <EditText
                    android:id="@+id/MultiVendor_prod_qty_refund"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:background="@drawable/editext_border"
                    android:layout_weight="0.5"
                    android:padding="5dp"
                    android:digits="0123456789"
                    android:inputType="number"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_Subtotal_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/Subtotal"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_Subtotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_TaxAmount_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/TaxAmount"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_TaxAmount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_DiscountAmount_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/Discount"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_DiscountAmount"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="1.0"

                >

                <TextView
                    android:id="@+id/MultiVendor_RowTotal_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:text="@string/RowTotal"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_13sp" />

                <TextView
                    android:id="@+id/MultiVendor_RowTotal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="0.5"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_11sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/MultiVendor_item_id"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone" />

            <TextView
                android:id="@+id/remaining_quantity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>