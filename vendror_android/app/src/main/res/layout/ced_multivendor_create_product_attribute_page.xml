                <Button
                    android:id="@+id/MultiVendor_FrontendProperties"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/corner"
                    android:gravity="start|center"
                    android:padding="@dimen/pad_10dp"
                    android:text="@string/FrontendProperties"
                    android:textColor="@color/white"
                    android:textSize="@dimen/txt_15sp" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:id="@+id/MultiVendor_QuickSearch_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0">

                <TextView
                    android:id="@+id/MultiVendor_QuickSearch_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:gravity="center_vertical"
                    android:text="@string/QuickSearch"
