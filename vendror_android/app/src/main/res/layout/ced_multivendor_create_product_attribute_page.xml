                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:gravity="center_vertical"
                    android:text="@string/ProductviewPage"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_15sp" />

                <Spinner
                    android:id="@+id/MultiVendor_ProductviewPage"
                    style="@style/SpinnerTheme"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/backgroundg_spinner" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/MultiVendor_Productlisting_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0">

                <TextView
                    android:id="@+id/MultiVendor_ProductListing_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:gravity="center_vertical"
                    android:text="@string/ProductListing"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_15sp" />

                <Spinner
                    android:id="@+id/MultiVendor_Productlisting"
                    style="@style/SpinnerTheme"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/backgroundg_spinner" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/MultiVendor_Sorting_Productlisting_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0">

                <TextView
                    android:id="@+id/MultiVendor_Sorting_ProductListing_head"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:gravity="center_vertical"
                    android:text="@string/Sorting_ProductListing"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_15sp" />

                <Spinner
                    android:id="@+id/MultiVendor_Sorting_Productlisting"
                    style="@style/SpinnerTheme"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/backgroundg_spinner" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/white"
                    app:cardUseCompatPadding="true">

                    <Button
                        android:id="@+id/MultiVendor_Manage_Labels"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/corner"
                        android:gravity="start|center"
                        android:padding="@dimen/pad_10dp"
                        android:text="@string/MangeLabels"
                        android:textColor="@color/white"
                        android:textSize="@dimen/txt_15sp" />
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/MultiVendor_Note_manage_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/pad_5dp"
            android:text="@string/Note_manage_label"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_13sp" />

        <LinearLayout
            android:id="@+id/MultiVendor_Manage_Labels_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pad_5dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0">

                <TextView
                    android:id="@+id/MultiVendor_Default_Store_View"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:gravity="center"
                    android:text="@string/DefaultStoreView"
                    android:textColor="@color/black" />

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/MultiVendor_edt_Default_Store_View"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/editext_border" />

            </LinearLayout>

            <LinearLayout
                android:id="@+id/store_label"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/MultiVendor_Add_button_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:id="@+id/MultiVendor_dynamic_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="vertical" />

                <Button
                    android:id="@+id/MultiVendor_AddOptions"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/corner"
                    android:text="@string/AddOption"
                    android:textAllCaps="false"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/MultiVendor_SaveAttribute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pad_5dp"
            android:background="@drawable/button_style"
            android:text="@string/save"
            android:textColor="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="@dimen/pad_15dp" />
    </LinearLayout>
</ScrollView>