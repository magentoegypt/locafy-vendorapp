<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/multiple_images_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="5dp"
    android:weightSum="3">

    <ImageView
        android:id="@+id/MultiVendor_productimage"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:layout_weight="1"
        android:src="@drawable/placeholder"
        android:adjustViewBounds="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/MultiVendor_clickproductimage"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginLeft="@dimen/pad_30dp"
        android:background="@drawable/button_shape"
        android:shadowColor="#112FA8"
        android:shadowDx="20"
        android:shadowDy="20"
        android:visibility="invisible"
        android:shadowRadius="25"
        android:text="@string/takephoto"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        app:layout_constraintTop_toTopOf="@id/MultiVendor_productimage"
        app:layout_constraintStart_toEndOf="@id/MultiVendor_productimage"/>

    <Button
        android:id="@+id/MultiVendor_browseproductimage"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:visibility="invisible"
        android:layout_marginLeft="@dimen/pad_30dp"
        android:background="@drawable/button_shape"
        android:shadowColor="#112FA8"
        android:shadowDx="20"
        android:shadowDy="20"
        android:shadowRadius="25"
        android:text="@string/browse"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="@id/MultiVendor_productimage"
        app:layout_constraintStart_toEndOf="@id/MultiVendor_productimage"/>

    <CheckBox
        android:id="@+id/default_checkbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Default"
        android:theme="@style/WhiteCheck"
        android:layout_margin="5dp"
        android:buttonTint="@color/secondary_color"
        app:layout_constraintStart_toEndOf="@id/MultiVendor_clickproductimage"
        app:layout_constraintTop_toTopOf="@id/MultiVendor_productimage"
        app:layout_constraintBottom_toBottomOf="@id/MultiVendor_productimage"
        app:layout_constraintEnd_toStartOf="@id/remove_image"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/imagetitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginStart="@dimen/_5sdp"
        app:layout_constraintTop_toTopOf="@id/MultiVendor_productimage"
        app:layout_constraintBottom_toBottomOf="@id/MultiVendor_productimage"
        app:layout_constraintEnd_toStartOf="@id/remove_image"
        app:layout_constraintStart_toEndOf="@id/MultiVendor_productimage"
        />

    <ImageView
        android:id="@+id/remove_image"
        android:layout_width="wrap_content"
        android:layout_height="30dp"
        android:src="@drawable/remove"
        android:padding="10dp"
        app:layout_constraintTop_toTopOf="@id/MultiVendor_productimage"
        app:layout_constraintBottom_toBottomOf="@id/MultiVendor_productimage"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>