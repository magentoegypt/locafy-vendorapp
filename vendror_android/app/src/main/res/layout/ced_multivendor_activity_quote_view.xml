<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/MultiVendor_viewA"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ScrollView
            android:id="@+id/MultiVendor_mainscroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:id="@+id/MultiVendor_linearLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:id="@+id/MultiVendor_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/MultiVendor_quote_increment_id"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.75"
                            android:background="@color/header_color"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:textSize="@dimen/txt_15sp" />

                        <Button
                            android:id="@+id/createpo"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.25"
                            android:background="@drawable/border_button_apptheme"
                            android:text="@string/CreatePO"
                            android:textColor="@color/TextColor"
                            android:visibility="gone" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>


                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/decision_section"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="5dp"
                    android:gravity="center"
                    android:weightSum="3"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/request_id">

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/accept"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_save_style"
                        android:backgroundTint="@color/green_bg"
                        android:onClick="acceptQuotation"
                        android:text="@string/accept"
                        android:textColor="@color/white"
                        android:visibility="gone" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/decline"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_save_style"
                        android:backgroundTint="@color/red"
                        android:onClick="declineQuotation"
                        android:text="@string/decline"
                        android:textColor="@color/white"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/accept"
                        app:layout_constraintTop_toBottomOf="@+id/request_id" />

                    <androidx.appcompat.widget.AppCompatButton
                        android:id="@+id/create_po"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/button_save_style"
                        android:onClick="createPO"
                        android:text="@string/CreatePO"
                        android:textColor="@color/white"
                        android:visibility="gone"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@id/accept"
                        app:layout_constraintTop_toBottomOf="@+id/request_id" />

                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.cardview.widget.CardView
                    android:id="@+id/MultiVendor_view2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/MultiVendor_QuoteAccountInformation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/AppTheme"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:paddingEnd="0dp"
                            android:text="@string/QuoteAccountInformation"
                            android:textColor="@color/TextColor"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/MultiVendor_orderdate_head"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/MultiVendor_orderdate_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:paddingStart="5dp"
                            android:paddingEnd="5dp"
                            android:text="@string/quotedate"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/MultiVendor_order_status_head"
                            app:layout_constraintEnd_toStartOf="@+id/MultiVendor_quoteDate"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/MultiVendor_QuoteAccountInformation" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/MultiVendor_quoteDate"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="start|center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"
                            app:layout_constraintBottom_toBottomOf="@+id/MultiVendor_orderdate_head"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/MultiVendor_orderdate_head"
                            app:layout_constraintTop_toTopOf="@+id/MultiVendor_orderdate_head" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/MultiVendor_order_status_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:paddingStart="5dp"
                            android:paddingEnd="5dp"
                            android:text="@string/OrderStatus"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toTopOf="@+id/MultiVendor_PurchasedFrom_head"
                            app:layout_constraintEnd_toStartOf="@+id/MultiVendor_QuoteStatus"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/MultiVendor_orderdate_head" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/MultiVendor_QuoteStatus"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="start|center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"
                            app:layout_constraintBottom_toBottomOf="@+id/MultiVendor_order_status_head"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/MultiVendor_order_status_head"
                            app:layout_constraintTop_toTopOf="@+id/MultiVendor_order_status_head" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/MultiVendor_PurchasedFrom_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:layout_marginBottom="5dp"
                            android:paddingStart="5dp"
                            android:paddingEnd="5dp"
                            android:text="@string/QuoteCreatedFrom"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/MultiVendor_QuoteCreatedFrom"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/MultiVendor_order_status_head" />

                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/MultiVendor_QuoteCreatedFrom"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:gravity="start|center"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"
                            app:layout_constraintBottom_toBottomOf="@+id/MultiVendor_PurchasedFrom_head"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/MultiVendor_PurchasedFrom_head"
                            app:layout_constraintTop_toTopOf="@+id/MultiVendor_PurchasedFrom_head" />
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:visibility="gone"
                    android:id="@+id/MultiVendor_views"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/MultiVendor_AccountInformation_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/AppTheme"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/AccountInformation"
                            android:textColor="@color/TextColor"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_CustomerName_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="@string/CustomerName"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/MultiVendor_CustomerName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_Email_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="@string/Email"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/MultiVendor_Email"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_CustomerGroup_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="@string/CustomerGroup"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/MultiVendor_CustomerGroup"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />
                        </LinearLayout>

                    </LinearLayout>

                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:visibility="gone"
                    android:id="@+id/MultiVendor_view4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:id="@+id/Shipping_Address_linear"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/MultiVendor_BillingAddress_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/AppTheme"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/adressinfotext"
                            android:textColor="@color/TextColor"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                        <androidx.constraintlayout.widget.ConstraintLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/MultiVendor_shipping_ship_to"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toTopOf="parent" />

                            <TextView
                                android:id="@+id/MultiVendor_shipping_street"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_ship_to" />

                            <TextView
                                android:id="@+id/MultiVendor_shipping_city"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toStartOf="@id/MultiVendor_shipping_state"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_street" />

                            <TextView
                                android:id="@+id/MultiVendor_shipping_state"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toStartOf="@id/MultiVendor_shipping_pincode"
                                app:layout_constraintStart_toEndOf="@+id/MultiVendor_shipping_city"
                                app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_street" />

                            <TextView
                                android:id="@+id/MultiVendor_shipping_pincode"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:gravity="start|center"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toEndOf="@+id/MultiVendor_shipping_state"
                                app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_street" />

                            <TextView
                                android:id="@+id/MultiVendor_shipping_country"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_city" />

                            <TextView
                                android:id="@+id/MultiVendor_shipping_phone"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"
                                app:layout_constraintEnd_toEndOf="parent"
                                app:layout_constraintStart_toStartOf="parent"
                                app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_country" />

                        </androidx.constraintlayout.widget.ConstraintLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/MultiVendor_view8"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/MultiVendor_ProductInfo_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/AppTheme"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/quoted_items"
                            android:textColor="@color/TextColor"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:id="@+id/dynamic_quotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <androidx.cardview.widget.CardView
                    android:id="@+id/MultiVendor_view15"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/MultiVendor_Comments_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/AppTheme"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/ChatHistoryInformation"
                            android:textColor="@color/TextColor"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/MultiVendor_dynamic_comment"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="vertical" />

                        <TextView
                            android:id="@+id/message_txt"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="5dp"
                            android:text="@string/message"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                        <androidx.appcompat.widget.AppCompatEditText
                            android:id="@+id/message"
                            android:layout_width="match_parent"
                            android:layout_height="100dp"
                            android:layout_margin="5dp"
                            android:background="@drawable/editext_border"
                            android:gravity="start"
                            android:hint="@string/enter_your_message_here"
                            android:inputType="text"
                            android:minEms="10"
                            android:padding="5dp"
                            android:textSize="13sp" />

                        <androidx.appcompat.widget.AppCompatButton
                            android:id="@+id/send_message"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_margin="5dp"
                            android:background="@drawable/button_save_style"
                            android:onClick="sendNewMessage"
                            android:padding="10dp"
                            android:text="@string/sendmessage"
                            android:textColor="@color/white"
                            android:visibility="visible"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@id/accept"
                            app:layout_constraintTop_toBottomOf="@+id/request_id" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/MultiVendor_view7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/whitebackground"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/MultiVendor_InvoiceTotals"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="@color/AppTheme"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/quotes_total_label"
                            android:textColor="@color/TextColor"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_subtotal_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_weight="0.5"
                                android:text="@string/Subtotal"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp" />

                            <TextView
                                android:id="@+id/Subtotal"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_grandtotalearned_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_weight="0.5"
                                android:text="@string/GrandTotal"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp" />

                            <TextView
                                android:id="@+id/MultiVendor_grandtotalearned"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_TotalDue_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_weight="0.5"
                                android:text="@string/TotalDue"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp" />

                            <TextView
                                android:id="@+id/MultiVendor_TotalDue"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:visibility="gone"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_Status_Spinner"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="2dp"
                                android:layout_weight="0.5"
                                android:text="@string/Status"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp"
                                android:textStyle="bold" />

                            <Spinner
                                android:id="@+id/MultiVendor_spn_rfq_status"
                                style="@style/SpinnerTheme"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_margin="@dimen/pad_2dp"
                                android:layout_weight="0.5"
                                android:entries="@array/rfq_status"
                                android:paddingStart="@dimen/pad_2dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/pad_30dp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <Button
                    android:id="@+id/save_quote"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:background="@color/AppTheme"
                    android:text="@string/SaveQuote"
                    android:textColor="@color/TextColor" />

            </LinearLayout>
        </ScrollView>
    </RelativeLayout>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/MultiVendor_fab"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="41dp"
        android:clickable="true"
        android:focusable="true"
        android:src="@drawable/add_comment"
        app:backgroundTint="@color/AppTheme"
        app:layout_anchor="@id/MultiVendor_viewA"
        app:layout_anchorGravity="bottom|right|end"
        app:rippleColor="@color/white" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>