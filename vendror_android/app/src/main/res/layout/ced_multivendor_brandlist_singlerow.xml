<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="false"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:orientation="vertical"
    android:layout_margin="2dp"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        app:cardUseCompatPadding="true"
        android:id="@+id/MultiVendor_view"
        android:background="@color/darker_gray">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"

            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1"
                android:layout_margin="5dp">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight=".5"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:id="@+id/MultiVendor_brand_logo"
                    android:layout_gravity="center"
                    />
                    <TextView
                        android:id="@+id/MultiVendor_brand_logo_tag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/brand_logo"
                        android:layout_margin="2dp"/>
                    <TextView
                        android:id="@+id/MultiVendor_picurl_logo"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:visibility="gone"
                        android:textStyle="bold"
                        android:text="@string/brand_logo"
                        android:layout_margin="2dp"/>


                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight=".5"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:layout_height="wrap_content">
                <ImageView
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:id="@+id/MultiVendor_brand_thumbnail"
                    android:layout_gravity="center"
                    />
                    <TextView
                        android:id="@+id/MultiVendor_brand_thumbnail_tag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/brand_thumbnail"
                        android:layout_margin="2dp"/>
                    <TextView
                        android:id="@+id/MultiVendor_picurl_thumbnail"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:visibility="gone"
                        android:textStyle="bold"
                        android:text="@string/brand_logo"
                        android:layout_margin="2dp"/>
                    </LinearLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_weight="1"
                android:layout_margin="5dp"
                >
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/ebebebe"/>
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="5dp"
                android:weightSum="5"
                >
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_margin="5dp"
                    android:layout_weight="2"
                    >
                    <TextView
                        android:id="@+id/MultiVendor_brandIDtag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/brand_id"
                        android:layout_margin="2dp"

                        />
                    <TextView
                        android:id="@+id/MultiVendor_brand_name_tag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/brand_name"
                        android:layout_margin="2dp"

                        />
                    <TextView
                        android:id="@+id/MultiVendor_brand_creation_tag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/brand_creation"
                        android:layout_margin="2dp"

                        />


                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_weight=".5"
                    android:layout_margin="5dp"
                    >
                    <TextView
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@color/ebebebe"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_margin="5dp"
                    android:layout_weight="2.5"
                    >
                    <TextView
                        android:id="@+id/MultiVendor_brand_id"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/AppTheme"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />

                    <TextView
                        android:id="@+id/MultiVendor_brand_name"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/main_color_gray"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />
                    <TextView
                        android:id="@+id/MultiVendor_brand_creation"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/main_color_gray"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />

                </LinearLayout></LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp"
                android:weightSum="1">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="35dp"
                    android:id="@+id/MultiVendor_edit"
                    android:text="@string/editetxt"
                    android:layout_weight="0.5"
                    android:gravity="center"
                    android:background="@drawable/button_style"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    />
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="35dp"
                    android:id="@+id/MultiVendor_delete"
                    android:text="@string/Delete"
                    android:layout_weight="0.5"
                    android:gravity="center"
                    android:background="@drawable/button_delete_style"
                    android:layout_marginStart="2dp"
                    android:textColor="@color/white"
                    android:textStyle="bold"/>
            </LinearLayout>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/MultiVendor_picurl"
            android:visibility="gone"/>



    </androidx.cardview.widget.CardView>
</RelativeLayout>
