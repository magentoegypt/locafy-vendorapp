<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/pad_10dp">

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/storeVisibility"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:gravity="center"
        android:padding="5dp"
        android:text="@string/score_visibility"
        android:textAllCaps="true"
        android:textColor="@color/textcolor"
        android:textSize="22sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/defaultValueTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:layout_marginTop="@dimen/pad_10dp"
        android:gravity="start|center_vertical"
        android:padding="5dp"
        android:text="@string/default_value"
        android:textColor="@color/textcolor"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/storeVisibility" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/defaultValue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:background="@drawable/editext_border"
        android:gravity="start|center_vertical"
        android:padding="5dp"
        android:text=""
        android:textColor="@color/textcolor"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/defaultValueTitle" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/visibilityTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:gravity="start|center_vertical"
        android:padding="5dp"
        android:text="@string/visiblity"
        android:textColor="@color/textcolor"
        android:textSize="18sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/defaultValue" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/visibleStoreListSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/visibilityTitle">

        <LinearLayout
            android:id="@+id/visibleStoreList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </androidx.core.widget.NestedScrollView>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/saveStoreRating"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/pad_5dp"
        android:background="@color/AppTheme"
        android:text="@string/save"
        android:textColor="@color/white"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/visibleStoreListSection" />

</androidx.constraintlayout.widget.ConstraintLayout>