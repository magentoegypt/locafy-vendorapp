<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/pad_5dp"
        android:orientation="horizontal"
        android:weightSum="1.0"


        >

        <TextView
            android:id="@+id/MultiVendor_dynamic_head"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.5"
            android:gravity="start|center"
            android:text="@string/CustomerGroup"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_13sp" />

        <TextView
            android:id="@+id/MultiVendor_dynamic_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.5"
            android:gravity="start|center"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />

    </LinearLayout>
</LinearLayout>