<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/parent"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="3dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/error_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textSize="16sp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/verticalguideline"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.38" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/ticket_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="10dp"
            android:text="@string/Chat"
            android:textColor="@color/red_republichub"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/general_info"
            android:layout_width="0dp"
            android:layout_height="45dp"
            android:background="@color/AppTheme"
            android:clickable="false"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="@string/convesation"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/ticket_title" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/add_new_tkt"
            android:layout_width="wrap_content"
            android:layout_height="35dp"
            android:layout_marginEnd="3dp"
            android:background="@drawable/button_save_style"
            android:padding="10dp"
            android:text="@string/reply"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/general_info"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/general_info" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/department_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/Department"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/general_info" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/department_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/general_info" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/status_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/Status"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/department_text" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/status_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/department_text" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/ticket_created_at"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/status_text" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tkt_created_at_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/status_text" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/order_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/order"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tkt_created_at_text" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/order_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/tkt_created_at_text" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/chat_list"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:background="@color/whitebackground"
            android:nestedScrollingEnabled="true"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@+id/order_text" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/replymessage"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/chat_list" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/reply_message"
            android:layout_width="0dp"
            android:layout_height="80dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/border2"
            android:gravity="start"
            android:padding="5dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/chat_list" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/status_value_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/status"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/reply_message" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/transaction_id_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:backgroundTint="@color/black"
            android:padding="5dp"
            android:text=""
            app:layout_constraintBottom_toBottomOf="@+id/status_value_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/reply_message" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/apply_signature_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/apply_signature"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/status_value_title" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/apply_signature"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:backgroundTint="@color/black"
            android:padding="5dp"
            android:text=""
            app:layout_constraintBottom_toBottomOf="@+id/apply_signature_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/status_value_title" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            android:text="@string/apply_signature"
            app:layout_constraintBottom_toBottomOf="@+id/add_attachment"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/apply_signature" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/add_attachment"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/Choosefile"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/apply_signature" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/add_attachment_file"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:padding="5dp"
            app:layout_constraintBottom_toBottomOf="@+id/add_attachment"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/add_attachment"
            app:layout_constraintTop_toBottomOf="@+id/apply_signature" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</ScrollView>