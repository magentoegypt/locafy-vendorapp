<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView

        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:id="@+id/MultiVendor_view"
        app:cardUseCompatPadding="true"
        android:background="@color/white"
        >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0"
                >
                <Button
                    android:layout_width="0dp"
                    android:layout_weight="0.60"
                    android:layout_height="wrap_content"
                    android:clickable="false"
                    android:text="@string/PAYMENTSSTATISTICS"
                    android:textSize="@dimen/txt_13sp"
                    android:id="@+id/MultiVendor_Payment_statistics_head"
                    android:textStyle="bold"
                    android:paddingStart="@dimen/pad_10dp"
                    android:textColor="@color/white"
                    android:gravity="start|center"
                    android:background="@color/AppTheme"
                    android:layout_below="@+id/MultiVendor_linearLayout"
                    android:layout_alignParentLeft="true"
                    android:layout_alignParentStart="true" />
                <Button
                    android:layout_width="0dp"
                    android:layout_weight="0.40"
                    android:background="@drawable/button_rqst_payment"
                    android:textColor="@color/black"
                    android:textAllCaps="false"
                    android:id="@+id/MultiVendor_mass_payment_rqst"
                    android:text="@string/MassRequestPayment"
                    android:layout_height="match_parent" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                >

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:weightSum="1.0"
                        >

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_weight="0.5"
                            android:layout_margin="@dimen/pad_5dp"

                            >
                            <Button
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="false"
                                android:text="@string/TotalPendingAmount"
                                android:id="@+id/MultiVendor_TotalPendingAmount_head"
                                android:textSize="@dimen/txt_11sp"
                                android:padding="@dimen/pad_10dp"
                                android:textStyle="bold"
                                android:paddingStart="@dimen/pad_10dp"
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:layout_margin="@dimen/pad_5dp"
                                android:background="@color/AppTheme"
                                android:layout_below="@+id/MultiVendor_linearLayout"
                                android:layout_alignParentLeft="true"
                                android:layout_alignParentStart="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/MultiVendor_TotalPendingAmount"
                                android:textColor="@color/black"
                                android:layout_margin="@dimen/pad_5dp"
                                android:textSize="@dimen/txt_11sp"
                                android:layout_gravity="center"
                                />

                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_weight="0.5"
                            android:layout_margin="@dimen/pad_5dp"
                            >
                            <Button
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:clickable="false"
                                android:text="@string/TotalRequestedAmount"
                                android:id="@+id/MultiVendor_TotalRequestedAmount_head"
                                android:textSize="@dimen/txt_11sp"
                                android:padding="@dimen/pad_10dp"
                                android:textStyle="bold"
                                android:paddingStart="@dimen/pad_10dp"
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:layout_margin="@dimen/pad_5dp"
                                android:background="@color/AppTheme"
                                android:layout_below="@+id/MultiVendor_linearLayout"
                                android:layout_alignParentLeft="true"
                                android:layout_alignParentStart="true" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:id="@+id/MultiVendor_TotalRequestedAmount"
                                android:textColor="@color/black"
                                android:layout_margin="@dimen/pad_5dp"
                                android:layout_gravity="center"
                                android:textSize="@dimen/txt_11sp"

                                />

                        </LinearLayout>

                    </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>