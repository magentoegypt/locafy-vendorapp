<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/loginback">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/loginback"

        >

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginStart="8dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginBottom="8dp"
            android:background="@color/white"
            card_view:cardUseCompatPadding="true">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_margin="15dp">

                <TextView
                    android:id="@+id/MultiVendor_vendorlogintag"
                    android:layout_width="wrap_content"
                    android:layout_height="60dp"
                    android:layout_centerHorizontal="true"
                    android:layout_marginTop="10dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:text="@string/VendorLogin"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/MultiVendor_linebelowvendortag"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/MultiVendor_vendorlogintag"
                    android:background="@color/ebebebe"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/MultiVendor_textbelowvendortag"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/MultiVendor_linebelowvendortag"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="10dp"
                    android:paddingLeft="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="@string/vendorlogintext"
                    android:textStyle="bold" />


                <EditText
                    android:id="@+id/email"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@+id/MultiVendor_textbelowvendortag"
                    android:layout_margin="10dp"
                    android:background="@drawable/curve"
                    android:backgroundTint="@color/TextHintColor"
                    android:hint="@string/emailhint"
                    android:padding="10dp"
                    android:singleLine="true"
                    android:textColor="@color/black"
                    android:textColorHint="@color/TextHintColor" />

                <EditText
                    android:id="@+id/user_password"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:layout_below="@+id/email"
                    android:layout_margin="10dp"
                    android:background="@drawable/curve"
                    android:backgroundTint="@color/TextHintColor"
                    android:hint="@string/Password"
                    android:padding="10dp"
                    android:password="true"
                    android:singleLine="true"
                    android:textColor="@color/black"
                    android:textColorHint="@color/TextHintColor" />

                <ImageView
                    android:id="@+id/maskpass"
                    android:layout_width="wrap_content"
                    android:layout_height="50dp"
                    android:layout_alignTop="@+id/user_password"
                    android:layout_alignEnd="@+id/user_password"
                    android:layout_marginEnd="@dimen/_7sdp"
                    android:backgroundTint="@color/AppTheme"
                    android:src="@drawable/hide_eye"
                    android:tint="@color/AppTheme"
                    android:visibility="visible" />

                <Button
                    android:id="@+id/login"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/user_password"
                    android:layout_marginStart="15dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginEnd="15dp"
                    android:layout_marginBottom="15dp"
                    android:background="@drawable/button_style"

                    android:text="@string/logintext"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/forgotpassword"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/login"
                    android:layout_marginLeft="10dp"
                    android:layout_marginBottom="@dimen/_15sdp"
                    android:gravity="center"
                    android:paddingLeft="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    android:text="@string/forgotpass"
                    android:textColor="@color/AppTheme"
                    android:textStyle="bold" />

                <!-- <TextView
                     android:id="@+id/signup"
                     android:layout_width="match_parent"
                     android:layout_height="wrap_content"
                     android:layout_below="@+id/forgotpassword"
                     android:layout_marginLeft="10dp"
                     android:paddingLeft="4dp"
                     android:paddingTop="4dp"
                     android:paddingBottom="4dp"
                     android:text="@string/createaccount"
                     android:textColor="@color/AppTheme"
                     android:textStyle="bold"/>-->
                <RelativeLayout
                    android:id="@+id/signupsection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/forgotpassword"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp">

                    <TextView
                        android:id="@+id/startsellingtext"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/startsellingonzeo"
                        android:textColor="@color/AppTheme"
                        android:textSize="@dimen/_12ssp" />

                    <TextView
                        android:id="@+id/signup"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_35sdp"
                        android:layout_below="@+id/startsellingtext"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:background="@drawable/border_apptheme"
                        android:gravity="center"
                        android:text="@string/signup"
                        android:textAllCaps="true"
                        android:textColor="@color/secondary_color"
                        android:textSize="@dimen/_12ssp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:id="@+id/policy_text"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/signup"
                        android:layout_marginTop="@dimen/_10sdp"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/terms_condition_text"
                            android:textColor="@color/AppTheme"
                            android:textSize="@dimen/_8ssp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/_3sdp"
                            android:onClick="TermsCondition"
                            android:text="@string/terms_txt"
                            android:textColor="@color/AppTheme"
                            android:textSize="@dimen/_8ssp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/policy_text"
                        android:gravity="center"
                        android:text="@string/policy_txt"
                        android:textColor="@color/AppTheme"
                        android:textSize="@dimen/_8ssp"
                        android:textStyle="bold"
                        android:visibility="gone" />


                </RelativeLayout>

                <TextView
                    android:id="@+id/MultiVendor_line_space"
                    android:layout_width="match_parent"
                    android:layout_height="2dp"
                    android:layout_below="@+id/signupsection"
                    android:layout_margin="10dp"
                    android:background="@color/darker_gray"
                    android:paddingLeft="4dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp" />

                <!--     <LinearLayout
                         android:id="@+id/MultiVendor_social_login_linear1"
                         android:layout_width="match_parent"
                         android:layout_height="wrap_content"
                         android:layout_below="@+id/MultiVendor_line_space"
                         android:layout_margin="@dimen/pad_10dp"
                         android:orientation="vertical"
                         android:visibility="gone"
                         android:weightSum="2.0">

                         <com.facebook.login.widget.LoginButton
                             android:id="@+id/MultiVendor_facebook_login_button1"
                             android:layout_width="match_parent"
                             android:layout_height="0dp"
                             android:layout_gravity="center_horizontal"
                             android:layout_margin="@dimen/pad_15dp"
                             android:layout_weight="1.0"

                             />

                         <com.google.android.gms.common.SignInButton
                             android:id="@+id/MultiVendor_sign_in_button1"
                             android:layout_width="match_parent"
                             android:layout_height="0dp"
                             android:layout_gravity="center_horizontal"
                             android:layout_margin="@dimen/pad_15dp"
                             android:layout_weight="1.0" />
                     </LinearLayout>-->

                <LinearLayout
                    android:id="@+id/MultiVendor_social_login_linear"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/MultiVendor_line_space"
                    android:layout_margin="@dimen/pad_10dp"
                    android:layout_marginTop="25dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:weightSum="2">

                    <LinearLayout
                        android:id="@+id/MageNative_social_login_google"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/googleselector"
                        android:orientation="horizontal"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="horizontal">
                            <!--  <ImageView
                                  android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:src="@drawable/signingoogle" />-->

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:drawableStart="@drawable/signingoogle"
                                android:drawablePadding="@dimen/pad_5dp"
                                android:text="@string/signupforgoogle"
                                android:textAllCaps="true"
                                android:textColor="@color/white"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <com.google.android.gms.common.SignInButton
                            android:id="@+id/MultiVendor_sign_in_button"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/MageNative_social_login_linear"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_margin="5dp"
                        android:layout_weight="1"
                        android:background="@drawable/fbselector"
                        android:orientation="horizontal"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_gravity="center"
                            android:gravity="center"
                            android:orientation="horizontal">

                            <!--  <ImageView
                                  android:layout_width="wrap_content"
                                  android:layout_height="wrap_content"
                                  android:src="@drawable/facebook" />-->

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="5dp"
                                android:drawableStart="@drawable/facebook"
                                android:drawablePadding="@dimen/pad_5dp"
                                android:text="@string/signupforfacebook"
                                android:textAllCaps="true"
                                android:textColor="@color/white"
                                android:textSize="15sp" />
                        </LinearLayout>

                        <com.facebook.login.widget.LoginButton
                            android:id="@+id/MultiVendor_facebook_login_button"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:visibility="gone" />
                    </LinearLayout>
                </LinearLayout>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>
