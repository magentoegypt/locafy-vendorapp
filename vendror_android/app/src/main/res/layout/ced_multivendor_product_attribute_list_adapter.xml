<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:descendantFocusability="blocksDescendants"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        app:cardUseCompatPadding="true"
        android:background="@color/white"
    >
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            >
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_AttributeCode_head"
                    android:text="@string/AttributeCode"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textSize="@dimen/txt_13sp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_AttributeCode"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textSize="@dimen/txt_11sp"
                    android:textColor="@color/black"

                    />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_AttributeLabel_head"
                    android:text="@string/AttributeLabel"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textSize="@dimen/txt_13sp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:textSize="@dimen/txt_11sp"
                    android:id="@+id/MultiVendor_AttributeLabel"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                    />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_Required_head"
                    android:text="@string/Required"
                    android:textSize="@dimen/txt_13sp"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:textSize="@dimen/txt_11sp"
                    android:id="@+id/MultiVendor_Required"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                    />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_System_head"
                    android:textSize="@dimen/txt_13sp"
                    android:text="@string/System"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_System"
                    android:textSize="@dimen/txt_11sp"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                    />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_Visible_head"
                    android:textSize="@dimen/txt_13sp"
                    android:text="@string/Visible"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:textSize="@dimen/txt_11sp"
                    android:id="@+id/MultiVendor_Visible"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                >
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:textSize="@dimen/txt_13sp"
                    android:id="@+id/MultiVendor_scope_head"
                    android:text="@string/scope"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_scope"
                    android:textSize="@dimen/txt_11sp"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:textSize="@dimen/txt_13sp"
                    android:id="@+id/MultiVendor_Searchable_head"
                    android:text="@string/Searchable"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_Searchable"
                    android:textSize="@dimen/txt_11sp"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_UseInLayeredNavigation_head"
                    android:text="@string/UseInLayeredNavigation"
                    android:textSize="@dimen/txt_13sp"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:textSize="@dimen/txt_11sp"
                    android:id="@+id/MultiVendor_UseInLayeredNavigation"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textColor="@color/black"

                />

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2.0"
                android:padding="@dimen/pad_5dp"
                android:visibility="gone">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_Comparable_head"
                    android:text="@string/Comparable"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textSize="@dimen/txt_13sp"
                    android:textColor="@color/black"
                />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.0"
                    android:id="@+id/MultiVendor_Comparable"
                    android:layout_margin="@dimen/pad_5dp"
                    android:textSize="@dimen/txt_11sp"
                    android:textColor="@color/black"

                />

            </LinearLayout>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:id="@+id/MultiVendor_attr_id"
                />

            <Button
                android:layout_width="match_parent"
                android:layout_height="?actionBarSize"
                android:id="@+id/Delete_Attr"
                android:text="@string/Delete"
                android:background="@color/red"
                android:textColor="@color/white"
                android:layout_margin="@dimen/pad_10dp"

                />
        </LinearLayout>




    </androidx.cardview.widget.CardView>
</LinearLayout>