<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:background="@color/white"
                    app:cardUseCompatPadding="true">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/MultiVendor_BenificiaryDetails_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/MultiVendor_linearLayout"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentLeft="true"
                            android:background="@color/AppTheme"
                            android:clickable="false"
                            android:gravity="start|center"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/BenificiaryDetails"
                            android:textColor="@color/white"
                            android:textSize="@dimen/txt_13sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_VendorName_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="@string/VendorName"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp" />

                            <TextView
                                android:id="@+id/MultiVendor_VendorName"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:visibility="gone"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0">

                            <TextView
                                android:id="@+id/MultiVendor_PaymentMethod_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="@string/PaymentMethod"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp"

                                />

                            <TextView
                                android:id="@+id/MultiVendor_PaymentMethod"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="Pending"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"

                                />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:orientation="horizontal"
                            android:weightSum="1.0"


                            >

                            <TextView
                                android:id="@+id/MultiVendor_BeneficiaryDetails_head"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="@string/PaymentMode"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_13sp"

                                />

                            <TextView
                                android:id="@+id/MultiVendor_BeneficiaryDetails"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="0.5"
                                android:text="n/a"
                                android:textColor="@color/black"
                                android:textSize="@dimen/txt_11sp"

                                />

                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@color/white"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/MultiVendor_Orderdetails_head"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/MultiVendor_linearLayout"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:background="@color/AppTheme"
                        android:clickable="false"
                        android:gravity="start|center"
                        android:paddingStart="@dimen/pad_10dp"
                        android:text="@string/ORDERDETAILS"
                        android:textColor="@color/white"
                        android:textSize="@dimen/txt_13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="vertical"
                        android:padding="@dimen/_5sdp"
                        android:weightSum="1.0">

                        <TextView
                            android:id="@+id/MultiVendor_order_details_head"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.1"
                            android:text="@string/ORDERDETAILS"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"
                            android:visibility="gone" />


                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/order_details_rv"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:visibility="visible" />

                    </LinearLayout>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:id="@+id/MultiVendor_view4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@color/white"
                app:cardUseCompatPadding="true">


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/MultiVendor_TRANSACTIONDETAILS_head"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/MultiVendor_linearLayout"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:background="@color/AppTheme"
                        android:clickable="false"
                        android:gravity="start|center"
                        android:paddingStart="@dimen/pad_10dp"
                        android:text="@string/TRANSACTIONDETAILS"
                        android:textColor="@color/white"
                        android:textSize="@dimen/txt_13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_TransactionID_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/TransactionID"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_TransactionID"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_TransactionDate_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/TransactionDate"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_TransactionDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_TransactionMode_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/TransactionMode"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_TransactionMode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_TransactionType_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/TransactionType"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_TransactionType"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_Amount_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/Amount"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_Amount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_AdjustmentAmount_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/AdjustmentAmount"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_AdjustmentAmount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_NetAmount_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/NetAmount"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_NetAmount"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_Notes_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/Notes"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_Notes"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"

                        >

                        <TextView
                            android:id="@+id/MultiVendor_pdf_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:text="@string/transaction_pdf"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_pdf"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:layout_weight="0.5"
                            android:textColor="@color/blue"
                            android:textSize="@dimen/txt_11sp"
                            android:text="@string/view_document"

                            />

                    </LinearLayout>


                </LinearLayout>

            </androidx.cardview.widget.CardView>


        </LinearLayout>
    </ScrollView>
</RelativeLayout>