<?xml version="1.0" encoding="utf-8"?>

<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_margin="2dp"
    app:cardUseCompatPadding="true"
    android:background="@color/white"
    tools:context="magentoegypt.locafy.addons.messaging.VendorAdmin.Ced_MultiVendor_Admin_MessageView"
    xmlns:android="http://schemas.android.com/apk/res/android">


<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
   >


    <TextView
        android:textColor="@color/AppTheme"
        android:textAllCaps="true"
        android:layout_marginTop="@dimen/pad_10dp"
        android:layout_marginLeft="@dimen/pad_10dp"
        android:text="@string/readmail"
        android:textSize="15dp"
        android:textStyle="bold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />



    <RelativeLayout
       android:gravity="end"
        android:layout_marginLeft="@dimen/pad_10dp"
        android:layout_marginRight="@dimen/pad_10dp"
        android:layout_marginTop="@dimen/pad_10dp"
        android:layout_width="match_parent"
        android:layout_height="40dp">
    <Button
        android:layout_centerVertical="true"
        android:textColor="@color/primary_material_light"
        android:background="@drawable/button_save_style"
        android:id="@+id/MultiVendor_reply"
        android:layout_width="70dp"
        android:layout_height="30dp"
        android:text="@string/reply"/>
    </RelativeLayout>

    <RelativeLayout
        android:gravity="end"
        android:layout_marginLeft="@dimen/pad_10dp"
        android:layout_marginRight="@dimen/pad_10dp"
        android:layout_marginTop="@dimen/pad_10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:text="Date"
            android:textSize="13dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/MultiVendor_display_date"/>
        <TextView
            android:visibility="gone"
            android:layout_marginLeft="@dimen/pad_5dp"
            android:layout_toRightOf="@+id/MultiVendor_display_date"
            android:text="Time"
            android:textSize="13dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/MultiVendor_display_time"/>

    </RelativeLayout>


    <TextView
        android:layout_marginLeft="@dimen/pad_10dp"
        android:layout_marginRight="@dimen/pad_10dp"
        android:textStyle="bold"
        android:layout_marginTop="@dimen/pad_10dp"
        android:text="subject"
        android:textSize="15dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/MultiVendor_display_subject"/>
    <TextView
        android:layout_marginBottom="@dimen/pad_10dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:layout_marginLeft="@dimen/pad_10dp"
        android:layout_marginRight="@dimen/pad_10dp"
        android:text="message"
        android:textSize="13dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/MultiVendor_display_message"/>

</LinearLayout>
</androidx.cardview.widget.CardView>