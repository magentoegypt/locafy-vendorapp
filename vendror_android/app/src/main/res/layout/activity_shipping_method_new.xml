<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/MultiVendor_mainscroll"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/MultiVendor_settingstagsection"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp">

                <ImageView
                    android:id="@+id/MultiVendor_settingsimage"
                    android:layout_width="wrap_content"
                    android:layout_height="20dp"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/truck"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/MultiVendor_transactionsettingstag"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/MultiVendor_transactionsettingstag"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:layout_toEndOf="@+id/MultiVendor_settingsimage"
                    android:maxLines="2"
                    android:text="@string/ShippingMethods"
                    android:textColor="@color/black"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/MultiVendor_save"
                    app:layout_constraintStart_toEndOf="@id/MultiVendor_settingsimage"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/MultiVendor_save"
                    android:layout_width="50dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/button_save_style"
                    android:gravity="center"
                    android:text="@string/save"
                    android:textColor="@color/primary_material_light"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:visibility="gone"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@id/MultiVendor_transactionsettingstag"
                    app:layout_constraintTop_toTopOf="parent" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/MultiVendor_linebelowtransactionsettingstagsection"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_below="@+id/MultiVendor_settingstagsection"
                android:background="@color/AppTheme"
                android:textStyle="bold" />

            <LinearLayout
                android:id="@+id/MultiVendor_forpaymentmethoods"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/MultiVendor_linebelowtransactionsettingstagsection"
                android:animateLayoutChanges="true"
                android:orientation="vertical"
                android:visibility="gone" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/message"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:layout_below="@+id/MultiVendor_linebelowtransactionsettingstagsection"
                android:gravity="center"
                android:visibility="gone" />
        </RelativeLayout>
    </RelativeLayout>
</ScrollView>