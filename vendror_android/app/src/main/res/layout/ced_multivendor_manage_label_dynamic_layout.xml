<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/pad_5dp"
        android:orientation="horizontal"
        android:weightSum="3.0">

        <TextView
            android:id="@+id/MultiVendor_heading"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.0"
            android:text="@string/Admin"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_15sp" />

        <EditText
            android:id="@+id/MultiVendor_default_value"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_marginEnd="@dimen/pad_5dp"
            android:layout_weight="1.2"
            android:background="@drawable/editext_border"
            android:padding="@dimen/pad_5dp"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />

        <Button
            android:id="@+id/MultiVendor_delete_row"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="0.8"
            android:background="@drawable/button_style"
            android:text="@string/Delete"
            android:textAllCaps="false"
            android:textColor="@color/white" />

    </LinearLayout>

    <CheckBox
        android:id="@+id/MultiVendor_default_chckbox"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/Default"
        android:theme="@style/WhiteCheck" />

    <TextView
        android:id="@+id/MultiVendor_option_id"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone" />
</LinearLayout>