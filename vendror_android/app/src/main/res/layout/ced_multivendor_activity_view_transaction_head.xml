<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView

        android:id="@+id/MultiVendor_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:background="@color/white"
        app:cardUseCompatPadding="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <Button
                android:id="@+id/MultiVendor_Transaction_statistics_head"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/MultiVendor_linearLayout"
                android:layout_alignParentStart="true"
                android:layout_alignParentLeft="true"
                android:background="@drawable/corner"
                android:clickable="false"
                android:gravity="start|center"
                android:paddingStart="@dimen/pad_10dp"
                android:text="@string/TRANSACTIONSSTATISTICS"
                android:textColor="@color/white"
                android:textSize="@dimen/txt_13sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3.0">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_2dp"
                        android:layout_weight="1.0"
                        android:orientation="vertical"

                        >

                        <Button
                            android:id="@+id/MultiVendor_TotalEarnedAmount_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/MultiVendor_linearLayout"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentLeft="true"
                            android:layout_margin="@dimen/pad_5dp"
                            android:background="@drawable/button_style"
                            android:clickable="false"
                            android:gravity="center"
                            android:padding="@dimen/pad_2dp"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/TotalEarnedAmount"
                            android:textColor="@color/white"
                            android:textSize="@dimen/txt_11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/MultiVendor_TotalEarnedAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_2dp"
                        android:layout_weight="1.0"
                        android:orientation="vertical"

                        >

                        <Button
                            android:id="@+id/MultiVendor_TotalPendingAmount_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/MultiVendor_linearLayout"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentLeft="true"
                            android:layout_margin="@dimen/pad_5dp"
                            android:background="@drawable/corner"
                            android:clickable="false"
                            android:gravity="center"
                            android:padding="@dimen/pad_2dp"
                            android:paddingStart="@dimen/pad_10dp"
                            android:text="@string/TotalPendingAmountTag"
                            android:textColor="@color/white"
                            android:textSize="@dimen/txt_11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/MultiVendor_TotalPendingAmount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_2dp"
                        android:layout_weight="1.0"
                        android:orientation="vertical">

                        <Button
                            android:id="@+id/MultiVendor_PendingTransfers_head"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/MultiVendor_linearLayout"
                            android:layout_alignParentStart="true"
                            android:layout_alignParentLeft="true"
                            android:layout_margin="@dimen/pad_5dp"
                            android:background="@drawable/button_style"
                            android:clickable="false"
                            android:gravity="center"
                            android:padding="@dimen/pad_2dp"
                            android:text="@string/PendingTransfers"
                            android:textColor="@color/white"
                            android:textSize="@dimen/txt_11sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/MultiVendor_PendingTransfers"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>

    </androidx.cardview.widget.CardView>
</LinearLayout>