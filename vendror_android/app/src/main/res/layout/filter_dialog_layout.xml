<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/dialog_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="visible">

        <TextView
            android:id="@+id/filter_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/AppTheme"
            android:padding="12dp"
            android:text="@string/Filter"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="17sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/deal_id_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/filter_header"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight=".3"
                android:text="@string/deal_id" />

            <EditText
                android:id="@+id/deal_id_edt"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".7"
                android:background="@drawable/editext_border"
                android:paddingStart="10dp"
                android:singleLine="true"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deal_name_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/deal_id_linear"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:id="@+id/product_name_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight=".3"
                android:text="@string/product_name" />

            <EditText
                android:id="@+id/product_name_edt"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".7"
                android:background="@drawable/editext_border"
                android:paddingStart="10dp"
                android:singleLine="true"

                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deal_price_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/deal_name_linear"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight=".3"
                android:text="@string/pricefrom" />

            <EditText
                android:id="@+id/price_edt"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".34"
                android:background="@drawable/editext_border"
                android:hint="@string/fromm"
                android:inputType="numberDecimal"
                android:paddingStart="10sp"
                android:singleLine="true"
                android:textSize="10sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0.02" />

            <EditText
                android:id="@+id/price_to_edt"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".34"
                android:background="@drawable/editext_border"
                android:hint="@string/to"
                android:inputType="numberDecimal"
                android:paddingStart="10sp"
                android:singleLine="true"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deal_period_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/deal_price_linear"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight=".3"
                android:text="@string/end_on" />

            <EditText
                android:id="@+id/period_from_edt"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".34"
                android:background="@drawable/editext_border"
                android:editable="false"
                android:hint="@string/from"
                android:paddingStart="10sp"
                android:singleLine="true"
                android:textSize="10sp" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="0.02" />

            <EditText
                android:id="@+id/period_to_edt"
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".34"
                android:background="@drawable/editext_border"
                android:editable="false"
                android:hint="@string/to"
                android:paddingStart="10sp"
                android:singleLine="true"
                android:textSize="10sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/deal_status_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/deal_period_linear"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:id="@+id/deal_status_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight=".3"
                android:text="@string/dealstatus" />

            <Spinner style="@style/SpinnerTheme"
                android:id="@+id/deal_status_spinner"

                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".6"

                android:entries="@array/deal_status" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/status_linear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/deal_status_linear"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:id="@+id/status_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="15dp"
                android:layout_weight=".3"
                android:text="@string/adminstatus" />

            <Spinner style="@style/SpinnerTheme"
                android:id="@+id/status_spinner"

                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".6"

                android:entries="@array/status" />
        </LinearLayout>


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/status_linear"
            android:layout_margin="5dp"
            android:weightSum="1">

            <TextView
                android:id="@+id/dialog_reset_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/pad_10dp"
                android:layout_marginStart="@dimen/pad_10dp"
                android:layout_weight="0.5"
                android:background="@color/AppTheme"
                android:padding="10dp"
                android:text="@string/Reset_filter"
                android:textAlignment="center"
                android:textColor="@color/white"
                />

            <TextView
                android:id="@+id/dialog_apply_btn"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="@dimen/pad_10dp"
                android:layout_marginStart="@dimen/pad_10dp"
                android:layout_weight="0.5"
                android:background="@color/AppTheme"
                android:padding="10dp"
                android:text="@string/Filter"
                android:textAlignment="center"
                android:textColor="@color/white"
                 />

        </LinearLayout>


    </RelativeLayout>


    <DatePicker
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:datePickerMode="spinner"
        android:visibility="gone" />

    <DatePicker
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:visibility="gone" />

</RelativeLayout>