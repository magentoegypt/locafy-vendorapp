<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whitebackground">

    <RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/whitebackground">

        <LinearLayout
            android:id="@+id/MultiVendor_filtersection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="5dp"
            android:orientation="vertical"
            android:weightSum="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="5dp"
                android:layout_marginTop="5dp"
                android:layout_marginEnd="5dp"
                android:layout_weight="0.5"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:weightSum="6"

                    >

                    <TextView
                        android:id="@+id/MultiVendor_txt_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/id"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:phoneNumber="true"


                        />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6"

                    >

                    <TextView
                        android:id="@+id/MultiVendor_txt_product_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/product_id"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_product_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"

                        android:padding="@dimen/pad_5dp"
                        android:phoneNumber="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6"

                    >

                    <TextView
                        android:id="@+id/MultiVendor_txt_customer_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/customer_id"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_customer_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"

                        android:padding="@dimen/pad_5dp"
                        android:phoneNumber="true" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6"

                    >

                    <TextView
                        android:id="@+id/MultiVendor_txt_customer_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:maxLines="1"
                        android:text="@string/Name"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_customer_name"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"
                        android:padding="@dimen/pad_5dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6">

                    <TextView
                        android:id="@+id/MultiVendor_txt_bid_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/bid_price"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_bid_price"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"
                        android:inputType="number"
                        android:padding="@dimen/pad_5dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6">

                    <TextView
                        android:id="@+id/MultiVendor_txt_bid_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/bid_date"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_bid_date"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"
                        android:hint="@string/dateformat"
                        android:padding="@dimen/pad_5dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6">

                    <TextView
                        android:id="@+id/MultiVendor_txt_bid_time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/bid_time"
                        android:textColor="@color/black"
                        android:textStyle="bold"


                        />

                    <EditText
                        android:id="@+id/MultiVendor_edt_bid_time"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"
                        android:padding="@dimen/pad_5dp" />

                </LinearLayout>


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                android:layout_weight="0.5"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6">

                    <TextView
                        android:id="@+id/MultiVendor_txt_winner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/winner"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/MultiVendor_edt_winner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"
                        android:padding="@dimen/pad_5dp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="1dp"
                    android:orientation="horizontal"
                    android:weightSum="6">

                    <TextView
                        android:id="@+id/MultiVendor_txt_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="2"
                        android:text="@string/status"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <EditText
                        android:id="@+id/MultiVendor_edt_status"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:layout_weight="4"
                        android:background="@drawable/editext_border"
                        android:padding="@dimen/pad_5dp" />

                </LinearLayout>


            </LinearLayout>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_below="@+id/MultiVendor_filtersection"
            android:orientation="horizontal"
            android:padding="2dp"
            android:weightSum="5">

            <TextView
                android:id="@+id/MultiVendor_unsetfilter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="2dp"
                android:layout_weight="2.5"
                android:background="@drawable/button_style"
                android:gravity="center"
                android:text="@string/Reset_filter"
                android:textColor="@color/TextColor"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/MultiVendor_setfilter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_margin="2dp"
                android:layout_weight="2.5"
                android:background="@drawable/button_style"
                android:gravity="center"
                android:text="@string/Filter"
                android:textColor="@color/TextColor"
                android:textSize="14sp"
                android:textStyle="bold" />


        </LinearLayout>

    </RelativeLayout>
</ScrollView>
