<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/tools"
    xmlns:card_view="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    app:ignore="NamespaceTypo">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="2dp"
        android:background="@color/white"
        card_view:cardUseCompatPadding="true">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_margin="5dp">

            <RelativeLayout
                android:id="@+id/MultiVendor_vendorstoresection"
                android:layout_width="match_parent"
                android:layout_height="50dp">

                <ImageView
                    android:id="@+id/MultiVendor_profileimage"
                    android:layout_width="35dp"
                    android:layout_height="35dp"
                    android:layout_centerVertical="true"
                    android:padding="5dp"
                    android:src="@drawable/userpics"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@+id/MultiVendor_profileimage"
                    android:layout_toRightOf="@+id/MultiVendor_profileimage"
                    android:text="New Store"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/MultiVendor_store_resetvalues"
                    android:layout_width="60dp"
                    android:layout_height="30dp"
                    android:layout_centerVertical="true"
                    android:layout_marginRight="@dimen/pad_5dp"
                    android:layout_toLeftOf="@+id/MultiVendor_store_updatestore"
                    android:background="@drawable/button_save_style"
                    android:gravity="center"
                    android:text="RESET"
                    android:textColor="@color/primary_material_light"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/MultiVendor_store_updatestore"
                    android:layout_width="60dp"
                    android:layout_height="30dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/button_save_style"
                    android:gravity="center"
                    android:text="SAVE"
                    android:textColor="@color/primary_material_light"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </RelativeLayout>

            <TextView
                android:id="@+id/MultiVendor_linebelowstoretag"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_below="@+id/MultiVendor_vendorstoresection"
                android:background="@color/ebebebe"
                android:textStyle="bold" />


            <!--<androidx.cardview.widget.CardView
                xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:card_view="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                card_view:cardUseCompatPadding="true"
                android:login_background="@color/white"
                android:layout_below="@+id/MultiVendor_linebelowstoretag"
                android:id="@+id/MultiVendor_storesectioncard"
                card_view:cardBackgroundColor="@color/white"
                >-->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/MultiVendor_linebelowstoretag"
                android:layout_marginTop="@dimen/pad_10dp">

                <LinearLayout
                    android:id="@+id/MultiVendor_generaltexttabs"
                    android:layout_width="match_parent"
                    android:layout_height="45dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <TextView
                        android:id="@+id/tabMultiVendor_store_basicinfo"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:background="@color/AppTheme"
                        android:gravity="center"
                        android:text="@string/storebasicinfo"
                        android:textColor="@color/white"
                        android:textSize="@dimen/txt_15sp"></TextView>

                    <TextView
                        android:id="@+id/tabMultiVendor_store_hourinfo"
                        android:layout_width="0dp"
                        android:layout_height="45dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="@string/storehourinfo"
                        android:textSize="@dimen/txt_15sp"></TextView>
                </LinearLayout>

                <TextView
                    android:id="@+id/MultiVendor_linebelowgeneraltexttabs"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_below="@+id/MultiVendor_generaltexttabs"
                    android:background="@color/ebebebe"
                    android:textStyle="bold" />

                <ScrollView
                    android:id="@+id/store_basicinfo_scrollview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@+id/MultiVendor_linebelowgeneraltexttabs"
                    android:layout_marginTop="@dimen/pad_5dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="@dimen/pad_5dp"
                        android:orientation="vertical">

                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_margin="2dp"
                            android:background="@color/white"
                            card_view:cardUseCompatPadding="true">

                            <RelativeLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">

                                <TextView
                                    android:id="@+id/MultiVendor_newstore_textheading"
                                    android:layout_width="wrap_content"
                                    android:layout_height="30dp"
                                    android:layout_marginLeft="@dimen/pad_5dp"
                                    android:layout_marginTop="@dimen/pad_5dp"
                                    android:text="@string/storepickupinfo"
                                    android:textColor="@color/black"
                                    android:textSize="15sp" />

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_below="@+id/MultiVendor_newstore_textheading"
                                    android:layout_marginStart="2dp"
                                    android:layout_marginTop="2dp"
                                    android:layout_marginEnd="2dp"
                                    android:layout_marginBottom="2dp"
                                    android:clickable="false"
                                    android:focusable="false"
                                    android:focusableInTouchMode="false"
                                    android:orientation="vertical">

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginLeft="5dp"
                                        android:layout_marginRight="5dp"
                                        android:layout_marginBottom="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storename"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_store_name"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:textColor="@color/black"
                                            android:textSize="11sp"


                                            />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storemanname"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold"

                                            />

                                        <EditText
                                            android:id="@+id/MultiVendor_storemanager_name"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:textColor="@color/black"
                                            android:textSize="11sp"

                                            />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storemanageremail"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold"

                                            />

                                        <EditText
                                            android:id="@+id/MultiVendor_storemanager_email"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/Country"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_store_country"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:focusable="false"
                                            android:padding="@dimen/pad_5dp"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/Status"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <Spinner

                                            android:id="@+id/MultiVendor_store_status"
                                            style="@style/spinner_style"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:entries="@array/enable_disable"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <!--                                    store address-->

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical"
                                        android:visibility="gone">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storeaddress"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />


                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:orientation="horizontal"
                                            android:weightSum="1">

                                            <EditText
                                                android:id="@+id/MultiVendor_Store_address"
                                                android:layout_width="0dp"
                                                android:layout_height="40dp"
                                                android:layout_margin="@dimen/pad_5dp"
                                                android:layout_weight="0.75"
                                                android:background="@drawable/curve"
                                                android:focusable="false"
                                                android:padding="@dimen/pad_5dp"
                                                android:textColor="@color/black"
                                                android:textSize="11sp" />


                                            <fragment
                                                android:id="@+id/place_autocomplete_fragment"
                                                android:name="com.google.android.gms.location.places.ui.PlaceAutocompleteFragment"
                                                android:layout_width="0dp"
                                                android:layout_height="40dp"
                                                android:layout_margin="@dimen/pad_5dp"
                                                android:layout_marginLeft="@dimen/pad_5dp"
                                                android:layout_weight="0.25" />

                                        </LinearLayout>

                                        <!--<EditText
                                            android:id="@+id/MultiVendor_Store_address"
                                            android:layout_height="40dp"
                                            android:layout_width="match_parent"
                                            android:textSize="11sp"
                                            android:textColor="@color/black"
                                            android:login_background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            />-->
<!--                                        <TextView-->
<!--                                            android:id="@+id/MultiVendor_Store_pickmylocation"-->
<!--                                            android:layout_width="wrap_content"-->
<!--                                            android:layout_height="wrap_content"-->
<!--                                            android:layout_margin="@dimen/pad_5dp"-->
<!--                                            android:text="@string/picklocation"-->
<!--                                            android:textColor="@color/AppTheme"-->
<!--                                            android:textSize="13sp" />-->
                                    </LinearLayout>

                                    <LinearLayout
                                        android:id="@+id/locationfields"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:orientation="vertical"
                                        android:paddingBottom="@dimen/pad_10dp"
                                        android:visibility="visible">

                                        <TextView
                                            android:id="@+id/location_title"
                                            android:layout_width="match_parent"
                                            android:layout_height="20dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storeaddress"
                                            android:layout_marginBottom="@dimen/_8sdp"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />


                                        <TextView
                                            android:id="@+id/MultiVendor_Store_selected_location"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:textColor="@color/AppTheme"
                                            android:textSize="13sp" />

                                        <fragment
                                            android:id="@+id/autocomplete_fragment"
                                            android:name="com.google.android.libraries.places.widget.AutocompleteSupportFragment"
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginStart="8dp"
                                            android:layout_marginTop="8dp"
                                            android:layout_marginEnd="8dp"
                                            app:layout="@layout/change_place" />


                                        <TextView
                                            android:id="@+id/MultiVendor_Store_pickmylocation"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/picklocation"
                                            android:textColor="@color/AppTheme"
                                            android:textSize="13sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/latitude"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_store_latitude"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:phoneNumber="true"
                                            android:textColor="@color/black"
                                            android:textSize="11sp"

                                            />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/longitude"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_store_longitude"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:phoneNumber="true"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storecity"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_storecity"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/storestate"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_storestate"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />

                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/postalCode"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_postal_code"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:maxLength="6"
                                            android:padding="@dimen/pad_5dp"
                                            android:phoneNumber="true"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/ContactNumber"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_contactnumber"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:phoneNumber="true"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>

                                    <LinearLayout
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_margin="5dp"
                                        android:orientation="vertical"
                                        android:visibility="gone">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:text="@string/shippingprice"
                                            android:textColor="@color/black"
                                            android:textSize="13sp"
                                            android:textStyle="bold" />

                                        <EditText
                                            android:id="@+id/MultiVendor_shippingprice"
                                            android:layout_width="match_parent"
                                            android:layout_height="40dp"
                                            android:layout_margin="@dimen/pad_5dp"
                                            android:background="@drawable/curve"
                                            android:padding="@dimen/pad_5dp"
                                            android:phoneNumber="true"
                                            android:textColor="@color/black"
                                            android:textSize="11sp" />
                                    </LinearLayout>
                                </LinearLayout>
                            </RelativeLayout>
                        </androidx.cardview.widget.CardView>
                    </LinearLayout>
                </ScrollView>

                <LinearLayout
                    android:id="@+id/store_hourinfo_linearview"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_below="@+id/MultiVendor_linebelowgeneraltexttabs"
                    android:layout_marginTop="@dimen/pad_5dp"
                    android:orientation="vertical"
                    android:visibility="invisible">

                    <androidx.cardview.widget.CardView xmlns:card_view="http://schemas.android.com/apk/res-auto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="2dp"
                        android:background="@color/white"
                        card_view:cardUseCompatPadding="true">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/MultiVendor_newstorehour_textheading"
                                android:layout_width="wrap_content"
                                android:layout_height="30dp"
                                android:layout_marginLeft="@dimen/pad_5dp"
                                android:layout_marginTop="@dimen/pad_5dp"
                                android:text="@string/storehour"
                                android:textColor="@color/black"
                                android:textSize="15sp" />

                            <ScrollView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_below="@+id/MultiVendor_newstorehour_textheading">

                                <LinearLayout
                                    android:id="@+id/linearlayout_storehour"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical" />

                            </ScrollView>
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
            </RelativeLayout>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>