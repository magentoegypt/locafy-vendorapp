<?xml version="1.0" encoding="utf-8"?>

<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="@dimen/_300sdp"
    android:layout_height="wrap_content"
    android:background="@drawable/border2"
    android:orientation="vertical"
    android:padding="10dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalguideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.40" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalguideline2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.67" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalguideline3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent=".94" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/sender_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/sender"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/sender_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint="@string/sender"
        android:padding="5dp"
        android:text=""
        app:layout_constraintEnd_toEndOf="@id/verticalguideline3"
        app:layout_constraintStart_toStartOf="@+id/verticalguideline"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/reciever_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/reciever"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sender_value" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/reciever_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint="@string/reciever"
        android:padding="5dp"
        android:text=""
        app:layout_constraintEnd_toEndOf="@id/verticalguideline3"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@id/sender_value"
        tools:ignore="SpeakableTextPresentCheck,TouchTargetSizeCheck" />


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/created_at_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/createdat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/reciever_value" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/created_at_from"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint=" from "
        android:padding="5dp"
        android:textColorHint="#757575"
        app:layout_constraintEnd_toEndOf="@+id/verticalguideline2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@id/reciever_value"
        tools:ignore="TextContrastCheck" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/created_at_to"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint="   to   "
        android:padding="5dp"
        android:textColorHint="#757575"
        app:layout_constraintEnd_toEndOf="@id/verticalguideline3"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline2"
        app:layout_constraintTop_toBottomOf="@id/reciever_value" />


    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/updated_at_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/updatedat"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/created_at_title" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/updated_at_from"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint=" from "
        android:padding="5dp"
        android:textColorHint="#757575"
        app:layout_constraintEnd_toEndOf="@+id/verticalguideline2"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@id/created_at_from"
        tools:ignore="TextContrastCheck" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/updated_at_to"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint="   to   "
        android:padding="5dp"
        android:textColorHint="#757575"
        app:layout_constraintEnd_toEndOf="@id/verticalguideline3"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline2"
        app:layout_constraintTop_toBottomOf="@id/created_at_to"
        tools:ignore="TextContrastCheck" />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/subject_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/Subject"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/updated_at_from" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/subject_value"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:hint="@string/subject"
        android:padding="5dp"
        android:text=""
        app:layout_constraintEnd_toEndOf="@id/verticalguideline3"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@id/updated_at_from"
        tools:ignore="TouchTargetSizeCheck,SpeakableTextPresentCheck" />

    <!--    android:backgroundTint="@color/red_republichub"-->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/resetfilter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="@drawable/corner"
        android:padding="@dimen/_5sdp"
        android:text="@string/Reset_filter"
        android:textColor="@color/whitebackground"
        app:layout_constraintEnd_toEndOf="@id/verticalguideline"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/subject_value"
        tools:ignore="TextContrastCheck" />

    <!--    android:backgroundTint="@color/red_republichub"-->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/applyfilter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="@drawable/corner"
        android:padding="@dimen/_5sdp"
        android:text="@string/applyfilter"
        android:textColor="@color/whitebackground"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@id/subject_value"
        tools:ignore="TextContrastCheck" />


</androidx.constraintlayout.widget.ConstraintLayout>