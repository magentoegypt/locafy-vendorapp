<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/editext_border"
    android:orientation="vertical"
    android:id="@+id/main"
    android:padding="10dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalguideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.486618" />

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/SKU"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/sku"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/startdate"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/Type"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sku"/>
    <!--  <androidx.appcompat.widget.AppCompatEditText
          android:id="@+id/sellproduct"
          app:layout_constraintWidth_percent="0.5"
          android:layout_width="0dp"
          android:background="@drawable/editext_border"
          android:layout_height="wrap_content"
          android:padding="5dp"
          android:layout_marginTop="@dimen/pad_5dp"
          android:text=""
          app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
          app:layout_constraintTop_toBottomOf="@+id/sku"/>-->
    <FrameLayout
        android:id="@+id/sellproduct_frame"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_height="wrap_content"
        android:padding="@dimen/pad_5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:background="@drawable/editext_border"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/sku">
        <Spinner
            android:id="@+id/typespinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="@style/SpinnerTheme"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/sku"/>
    </FrameLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/filter"
        android:backgroundTint="@color/AppTheme"
        android:textColor="@color/whitebackground"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.45"
        android:layout_marginTop="@dimen/pad_20dp"
        android:layout_height="wrap_content"
        android:text="@string/applyfilter"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@+id/sellproduct_frame"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/clearfilter"
        android:backgroundTint="@color/AppTheme"
        android:textColor="@color/whitebackground"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.45"
        android:layout_marginTop="@dimen/pad_20dp"
        android:layout_height="wrap_content"
        android:text="@string/Reset_filter"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@+id/sellproduct_frame"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>