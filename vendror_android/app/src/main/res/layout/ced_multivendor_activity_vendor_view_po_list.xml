<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/MultiVendor_viewA"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:descendantFocusability="blocksDescendants"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView

                android:id="@+id/MultiVendor_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@color/darker_gray"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <Button
                        android:id="@+id/MultiVendor_OrderList_txt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".85"
                        android:background="@color/AppTheme"
                        android:gravity="start|center"
                        android:paddingStart="@dimen/pad_10dp"
                        android:text="@string/POLIst"
                        android:textAllCaps="false"
                        android:textColor="@color/TextColor"
                        android:textSize="@dimen/txt_15sp" />

                    <LinearLayout
                        android:id="@+id/MultiVendor_filtersection"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_gravity="center"
                        android:layout_weight=".15"
                        android:background="@color/whitebackground"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:padding="@dimen/pad_5dp">

                        <ImageView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="2dp"
                            android:paddingEnd="@dimen/pad_10dp"
                            android:src="@drawable/filtericon" />

                    </LinearLayout>


                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_2dp">

                <TextView
                    android:id="@+id/MultiVendor_Count_total"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:textColor="@color/black"
                    android:textSize="@dimen/txt_15sp" />
            </androidx.cardview.widget.CardView>

            <TextView
                android:id="@+id/MultiVendor_text_msg"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:gravity="center"
                android:visibility="gone" />

            <ListView
                android:id="@+id/MultiVendor_quote_management_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </RelativeLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
