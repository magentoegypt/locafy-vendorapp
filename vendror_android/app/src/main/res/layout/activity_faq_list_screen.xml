<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="magentoegypt.locafy.addons.faq.FaqListScreen">

    <Button
        android:id="@+id/addFaq"
        android:layout_width="0dp"
        android:layout_height="@dimen/_40sdp"
        android:layout_margin="2dp"
        android:background="@color/AppTheme"
        android:gravity="center"
        android:paddingStart="@dimen/pad_10dp"
        android:paddingEnd="@dimen/pad_10dp"
        android:text="@string/add_faq_product"
        android:textAllCaps="false"
        android:textColor="@color/TextColor"
        android:textSize="@dimen/txt_15sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.8" />

    <ImageView
        android:id="@+id/filter_button_faq"
        android:layout_width="0dp"
        android:layout_height="@dimen/_40sdp"
        android:layout_marginEnd="2dp"
        android:padding="@dimen/pad_5dp"
        android:src="@drawable/filtericon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/addFaq"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.2" />

    <TextView
        android:id="@+id/faqtext_msg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/pad_5dp"
        app:layout_constraintTop_toBottomOf="@+id/addFaq"
        android:textAlignment="center"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recFaqList"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="5dp"
        android:layout_marginTop="@dimen/_8sdp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/addFaq"
        tools:listitem="@layout/faq_list_view" />
</androidx.constraintlayout.widget.ConstraintLayout>