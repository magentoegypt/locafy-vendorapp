<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/editext_border"
    android:orientation="vertical"
    android:id="@+id/main"
    android:padding="10dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalguideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.486618" />

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/id"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/id_from"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:inputType="number"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        android:hint="@string/from"
        android:background="@drawable/editext_border"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/id_to"
        android:layout_width="0dp"
        android:inputType="number"
        app:layout_constraintWidth_percent="0.5"
        android:layout_height="wrap_content"
        android:background="@drawable/editext_border"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        android:hint="@string/to"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/id_from"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/auction_price"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/id_to"/>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/auctionprice_from"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:hint="@string/from"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:textSize="@dimen/_15sdp"
        android:text=""
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/id_to"/>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/auctionprice_to"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:hint="@string/to"
        android:textSize="@dimen/_15sdp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/auctionprice_from"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/winning_price"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/auctionprice_to"/>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/winningprice__from"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:hint="@string/from"
        android:textSize="@dimen/_15sdp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/auctionprice_to"/>
    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/winningprice__to"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:background="@drawable/editext_border"
        android:hint="@string/to"
        android:textSize="@dimen/_15sdp"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/winningprice__from"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/Status"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/winningprice__to"/>

    <androidx.appcompat.widget.AppCompatEditText
        android:id="@+id/status"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        android:inputType="text"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/winningprice__to"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text="@string/binding_date"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/status"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/bindingdate"
        app:layout_constraintWidth_percent="0.5"
        android:layout_width="0dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:layout_marginTop="@dimen/pad_5dp"
        android:text=""
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/status"/>



    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/filter"
        android:backgroundTint="@color/AppTheme"
        android:textColor="@color/whitebackground"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.45"
        android:layout_marginTop="@dimen/pad_20dp"
        android:layout_height="wrap_content"
        android:text="@string/applyfilter"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@+id/bindingdate"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/clearfilter"
        android:backgroundTint="@color/AppTheme"
        android:textColor="@color/whitebackground"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.45"
        android:layout_marginTop="@dimen/pad_20dp"
        android:layout_height="wrap_content"
        android:text="@string/Reset_filter"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@+id/bindingdate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>