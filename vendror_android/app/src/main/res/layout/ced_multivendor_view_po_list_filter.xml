<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/whitebackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_POIncrementId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/POIncrementId"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_POIncrementId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_CustomerId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/CustomerId"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_CustomerId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_POPrice"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/POPrice"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_POPrice"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_POQty"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/POQty"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_POQty"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:gravity="center"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:visibility="gone"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_QuoteIncrementId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/QuoteIncrementId"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_QuoteIncrementId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
            </LinearLayout>


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_QuoteId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="Quote Id"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_QuoteId"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_CreatedAt"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/CreatedAt"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <EditText
                    android:id="@+id/MultiVendor_edt_CreatedAt"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:ellipsize="end"
                    android:focusable="false"
                    android:gravity="center_vertical"
                    android:inputType="number"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black"
                    android:textSize="12sp" />


            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_invoicestatus"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:gravity="center_vertical"
                    android:text="@string/invoice_status"
                    android:textColor="@color/black"
                    android:textSize="12sp" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_po_status"
                    android:layout_width="0dp"
                    android:layout_height="30dp"
                    android:layout_gravity="center"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:ellipsize="end"
                    android:entries="@array/po_status"
                    android:gravity="center_vertical"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:paddingEnd="10dp"
                    android:textSize="12sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/pad_2dp"
                android:orientation="horizontal"
                android:weightSum="2.0">


                <Button
                    android:id="@+id/MultiVendor_unsetfilter"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/pad_2dp"
                    android:layout_marginEnd="@dimen/pad_2dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/button_style"
                    android:gravity="center"
                    android:text="@string/Reset_filter"
                    android:textColor="@color/TextColor"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/MultiVendor_setfilter"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_gravity="center"
                    android:layout_marginStart="@dimen/pad_2dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/button_style"
                    android:gravity="center"
                    android:text="@string/Filter"
                    android:textColor="@color/TextColor"
                    android:textSize="12sp" />
            </LinearLayout>

            <TextView
                android:layout_width="@dimen/fab_margin"
                android:layout_height="@dimen/pad_2dp" />
        </LinearLayout>
    </ScrollView>
</RelativeLayout>