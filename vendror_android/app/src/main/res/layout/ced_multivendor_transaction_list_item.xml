<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/parent_item_view"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="1dp"
            android:background="@color/white"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_transaction_date_header"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/CreatedAt"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_CreatedAt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_TransactionId_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.6"
                        android:text="@string/TransactionId"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_TransactionId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"

                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_Amount_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/Amount"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_Amount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_AdjustmentAmount_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/AdjustmentAmount"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_AdjustmentAmount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"

                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_NetAmount_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/NetAmount"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_NetAmount"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_PaymentMode_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/PaymentMode"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_PaymentMode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <LinearLayout
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="Amount Description"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_Amount_Description_Text"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        android:visibility="gone" />

                    <LinearLayout
                        android:id="@+id/MultiVendor_Amount_Description_LL"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:orientation="vertical" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"

                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_Amount_Description_Label"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/amount_description"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_Amount_Description_Label_Value"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/MultiVendor_payment_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</RelativeLayout>