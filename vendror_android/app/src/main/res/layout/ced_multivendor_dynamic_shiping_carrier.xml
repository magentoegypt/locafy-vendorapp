<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2.0">

        <TextView
            android:id="@+id/MultiVendor_Carrier_Head"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pad_5dp"
            android:layout_weight="1.0"
            android:text="@string/Carrier"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />

        <EditText
            android:id="@+id/MultiVendor_Carrier"
            android:layout_width="0dp"
            android:layout_height="@dimen/_40sdp"
            android:layout_margin="@dimen/pad_5dp"
            android:layout_weight="1.0"
            android:background="@drawable/spinner_border"
            android:editable="false"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2.0">

        <TextView
            android:id="@+id/MultiVendor_Title_Head"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pad_5dp"
            android:layout_weight="1.0"
            android:text="@string/title"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />

        <EditText
            android:id="@+id/MultiVendor_Title"
            android:layout_width="0dp"
            android:layout_height="@dimen/_40sdp"
            android:layout_margin="@dimen/pad_5dp"
            android:layout_weight="1.0"
            android:background="@drawable/spinner_border"
            android:editable="false"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />


    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2.0">

        <TextView
            android:id="@+id/MultiVendor_Number_Head"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pad_5dp"
            android:layout_weight="1.0"
            android:text="@string/Number"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />

        <EditText
            android:id="@+id/MultiVendor_Number"
            android:layout_width="0dp"
            android:layout_height="@dimen/_40sdp"
            android:layout_margin="@dimen/pad_5dp"
            android:layout_weight="1.0"
            android:background="@drawable/spinner_border"
            android:textColor="@color/black"
            android:textSize="@dimen/txt_11sp" />


    </LinearLayout>

    <Button
        android:id="@+id/MultiVendor_delete_tracking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/AppTheme"
        android:padding="@dimen/pad_10dp"
        android:text="@string/Delete"
        android:textAllCaps="false"
        android:textColor="@color/white" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="@dimen/pad_20dp" />

    <TextView
        android:id="@+id/MultiVendor_carrier_value"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone" />


</LinearLayout>