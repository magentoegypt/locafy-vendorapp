<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/MultiVendor_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="2dp"
                android:background="@color/darker_gray"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <Button
                        android:id="@+id/MultiVendor_header_txt"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:background="@color/AppTheme"
                        android:gravity="left|center"
                        android:paddingLeft="@dimen/pad_10dp"
                        android:text="@string/CreditMemoList"
                        android:textAllCaps="false"
                        android:textColor="@color/TextColor"
                        android:textSize="@dimen/txt_15sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:orientation="horizontal"
                    android:weightSum="2.0">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:text="@string/SKUastrik" />

                    <EditText
                        android:id="@+id/edt_sku"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1.0"
                        android:background="@drawable/editext_border"
                        android:singleLine="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:orientation="horizontal"
                    android:visibility="visible"
                    android:weightSum="2.0">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:text="@string/price_astrik" />

                    <EditText
                        android:id="@+id/edt_price"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1.0"
                        android:background="@drawable/editext_border"
                        android:inputType="numberDecimal"
                        android:singleLine="true"

                        />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:orientation="horizontal"
                    android:weightSum="2.0">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:text="Stock *" />

                    <EditText
                        android:id="@+id/edt_stock"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1.0"
                        android:background="@drawable/editext_border"
                        android:digits="0123456789"
                        android:inputType="number"
                        android:singleLine="true" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:orientation="horizontal"
                    android:weightSum="2.0">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:text="Stock Availability *" />

                    <Spinner
                        android:id="@+id/edt_stock_availability"
                        style="@style/SpinnerTheme"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1.0"
                        android:entries="@array/stock_availability" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/linear_status"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:orientation="horizontal"
                    android:visibility="gone"
                    android:weightSum="2.0">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"
                        android:text="@string/Status" />

                    <Spinner
                        android:id="@+id/edt_status"
                        style="@style/SpinnerTheme"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.0"

                        android:entries="@array/prod_status" />
                </LinearLayout>

                <Button
                    android:id="@+id/save"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_10dp"
                    android:background="@color/AppTheme"
                    android:text="@string/save"
                    android:textColor="@color/white" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>