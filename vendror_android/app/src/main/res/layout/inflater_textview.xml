<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/_5sdp"
    android:paddingVertical="@dimen/_2sdp">

    <TextView
        android:id="@+id/dynamic_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:paddingHorizontal="@dimen/_4sdp"
        android:text="label Here"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/dynamic_tv_value"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_35sdp"
        android:layout_marginTop="@dimen/_3sdp"
        android:background="@drawable/edittext_bg"
        android:gravity="center_vertical"
        android:maxLines="1"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_4sdp"

        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:textColor="@color/textColoSecondry"
        app:layout_constraintStart_toStartOf="@+id/dynamic_label"
        app:layout_constraintTop_toBottomOf="@+id/dynamic_label" />
</androidx.constraintlayout.widget.ConstraintLayout>