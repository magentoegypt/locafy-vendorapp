<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/MultiVendor_mainscroll"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <LinearLayout
        android:id="@+id/MultiVendor_linearLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:id="@+id/MultiVendor_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@color/whitebackground"
            android:visibility="gone"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/MultiVendor_quote_increment_id"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="0.6"
                    android:background="@color/header_color"
                    android:clickable="false"
                    android:gravity="start|center"
                    android:paddingStart="@dimen/pad_10dp"
                    android:textSize="@dimen/txt_15sp" />

                <Button
                    android:id="@+id/createpo"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_weight="0.4"
                    android:background="@color/AppTheme"
                    android:text="@string/CreatePO"
                    android:textColor="@color/TextColor"
                    android:visibility="gone" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView

                android:id="@+id/MultiVendor_view2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@color/whitebackground"
                android:visibility="gone"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/MultiVendor_QuoteAccountInformation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@color/AppTheme"
                        android:clickable="false"
                        android:gravity="start|center"
                        android:paddingStart="@dimen/pad_10dp"
                        android:text="@string/QuoteAccountInformation"
                        android:textColor="@color/TextColor"
                        android:textSize="@dimen/txt_13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0">

                        <TextView
                            android:id="@+id/MultiVendor_orderdate_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/OrderDate"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_quoteDate"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0">

                        <TextView
                            android:id="@+id/MultiVendor_order_status_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/OrderStatus"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_QuoteStatus"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"


                        >

                        <TextView
                            android:id="@+id/MultiVendor_PurchasedFrom_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/QuoteCreatedFrom"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"

                            />

                        <TextView
                            android:id="@+id/MultiVendor_QuoteCreatedFrom"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"


                        >

                        <TextView
                            android:id="@+id/MultiVendor_TotalQuantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/TotalQuantity"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"

                            />

                        <TextView
                            android:id="@+id/TotalQuantity"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0"


                        >

                        <TextView
                            android:id="@+id/MultiVendor_quoted_total_price"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/QuotedTotalPrice"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"

                            />

                        <TextView
                            android:id="@+id/Total_quoted_total_price"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView

                android:id="@+id/MultiVendor_views"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@color/whitebackground"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <Button
                        android:id="@+id/MultiVendor_AccountInformation_head"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/MultiVendor_linearLayout"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:background="@color/AppTheme"
                        android:clickable="false"
                        android:gravity="start|center"
                        android:paddingStart="@dimen/pad_10dp"
                        android:text="@string/AccountInformation"
                        android:textColor="@color/TextColor"
                        android:textSize="@dimen/txt_13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0">

                        <TextView
                            android:id="@+id/MultiVendor_CustomerName_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/CustomerName"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"

                            />

                        <TextView
                            android:id="@+id/MultiVendor_CustomerName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0">

                        <TextView
                            android:id="@+id/MultiVendor_Email_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/Email"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp"

                            />

                        <TextView
                            android:id="@+id/MultiVendor_Email"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp"

                            />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="horizontal"
                        android:weightSum="1.0">

                        <TextView
                            android:id="@+id/MultiVendor_CustomerGroup_head"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:text="@string/CustomerGroup"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_13sp" />

                        <TextView
                            android:id="@+id/MultiVendor_CustomerGroup"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="0.5"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/MultiVendor_account_info_dynamic"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <androidx.cardview.widget.CardView
                android:id="@+id/MultiVendor_view3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:background="@color/whitebackground"
                app:cardUseCompatPadding="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <Button
                        android:id="@+id/MultiVendor_ShippingAddress_head"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@+id/MultiVendor_linearLayout"
                        android:layout_alignParentStart="true"
                        android:layout_alignParentLeft="true"
                        android:background="@color/AppTheme"
                        android:clickable="false"
                        android:gravity="start|center"
                        android:paddingStart="@dimen/pad_10dp"
                        android:text="@string/ShippingInformation"
                        android:textColor="@color/TextColor"
                        android:textSize="@dimen/txt_13sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/MultiVendor_billing_ship_to"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                        <TextView
                            android:id="@+id/MultiVendor_billing_street"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                        <TextView
                            android:id="@+id/MultiVendor_billing_city"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                        <TextView
                            android:id="@+id/MultiVendor_billing_state"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                        <TextView
                            android:id="@+id/MultiVendor_billing_pincode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                        <TextView
                            android:id="@+id/MultiVendor_billing_country"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />

                        <TextView
                            android:id="@+id/MultiVendor_billing_mobile"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_margin="@dimen/pad_5dp"
                            android:textColor="@color/black"
                            android:textSize="@dimen/txt_11sp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:visibility="gone"
            android:id="@+id/MultiVendor_view4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@color/whitebackground"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:id="@+id/Shipping_Address_linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/MultiVendor_BillingAddress_head"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/AppTheme"
                    android:clickable="false"
                    android:gravity="start|center"
                    android:paddingStart="@dimen/pad_10dp"
                    android:text="@string/ShippingAddress"
                    android:textColor="@color/TextColor"
                    android:textSize="@dimen/txt_13sp"
                    android:textStyle="bold" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/MultiVendor_shipping_ship_to"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <TextView
                        android:id="@+id/MultiVendor_shipping_street"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_ship_to" />

                    <TextView
                        android:id="@+id/MultiVendor_shipping_city"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toStartOf="@id/MultiVendor_shipping_state"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_street" />

                    <TextView
                        android:id="@+id/MultiVendor_shipping_state"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toStartOf="@id/MultiVendor_shipping_pincode"
                        app:layout_constraintStart_toEndOf="@+id/MultiVendor_shipping_city"
                        app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_street" />

                    <TextView
                        android:id="@+id/MultiVendor_shipping_pincode"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:gravity="start|center"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/MultiVendor_shipping_state"
                        app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_street" />

                    <TextView
                        android:id="@+id/MultiVendor_shipping_country"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_city" />

                    <TextView
                        android:id="@+id/MultiVendor_shipping_phone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/MultiVendor_shipping_country" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/MultiVendor_view8"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@color/whitebackground"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/MultiVendor_ProductInfo_head"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/AppTheme"
                    android:clickable="false"
                    android:gravity="start|center"
                    android:paddingStart="@dimen/pad_10dp"
                    android:text="@string/ItemsOrdered"
                    android:textColor="@color/TextColor"
                    android:textSize="@dimen/txt_13sp"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <LinearLayout
            android:id="@+id/dynamic_quotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <androidx.cardview.widget.CardView
            android:id="@+id/MultiVendor_view7"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="8dp"
            android:background="@color/whitebackground"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <Button
                    android:id="@+id/MultiVendor_InvoiceTotals"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@color/AppTheme"
                    android:clickable="false"
                    android:gravity="start|center"
                    android:paddingStart="@dimen/pad_10dp"
                    android:text="@string/proposal_total"
                    android:textColor="@color/TextColor"
                    android:textSize="@dimen/txt_13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_subtotal_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/Subtotal"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/Subtotal"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_grandtotalearned_head"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/GrandTotalEarned"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/MultiVendor_grandtotalearned"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:orientation="horizontal"
                    android:weightSum="1.0">

                    <TextView
                        android:id="@+id/MultiVendor_TotalDue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:text="@string/TotalDue"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_13sp" />

                    <TextView
                        android:id="@+id/TotalDue"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_margin="@dimen/pad_5dp"
                        android:layout_weight="0.5"
                        android:textColor="@color/black"
                        android:textSize="@dimen/txt_11sp" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/submit_po"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/pad_10dp"
            android:background="@color/AppTheme"
            android:text="@string/SubmitPO"
            android:textColor="@color/TextColor" />

    </LinearLayout>
</ScrollView>