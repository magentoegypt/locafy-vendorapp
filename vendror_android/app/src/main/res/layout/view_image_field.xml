<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    android:orientation="vertical">

    <TextView
        android:id="@+id/text_title"
        android:tag="text_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/pad_5dp"
        android:text="@string/profilepictag"
        android:textColor="@color/black"
        android:textSize="13sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/picture_field"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_margin="@dimen/pad_5dp"
            android:src="@drawable/placeholder" />

        <Button
            android:id="@+id/browse_picture"
            android:layout_width="wrap_content"
            android:layout_height="27dp"
            android:layout_marginStart="@dimen/pad_30dp"
            android:layout_marginTop="70dp"
            android:background="@drawable/button_shape"
            android:shadowColor="#112FA8"
            android:shadowDx="20"
            android:shadowDy="20"
            android:shadowRadius="25"
            android:text="@string/browse"
            android:textColor="#FFFFFF"
            android:textSize="11sp" />

    </LinearLayout>

</LinearLayout>