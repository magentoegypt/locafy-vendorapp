<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/pad_10dp"
            android:layout_marginEnd="@dimen/pad_10dp"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/MultiVendor_txt_attribute_code"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/AttributeCode"
                    android:textColor="@color/black" />

                <EditText
                    android:id="@+id/MultiVendor_edt_attribute_code"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/MultiVendor_txt_attribute_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/AttributeLabel"
                    android:textColor="@color/black" />

                <EditText
                    android:id="@+id/MultiVendor_edt_attribute_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/editext_border"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp"
                    android:textColor="@color/black" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_required"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/Required"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_required"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/selection"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_system"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/System"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_system"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/selection"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_visible"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/Visible"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_visible"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/selection"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_scope"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/scope"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_scope"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/scope"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_searchable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/Searchable"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_searchable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/selection"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_layered_navigation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/UseInLayeredNavigation"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_layered_navigation"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/layered"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="1.0">

                <TextView
                    android:id="@+id/MultiVendor_txt_Comparable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:text="@string/UseInLayeredNavigation"
                    android:textColor="@color/black" />

                <Spinner
                    android:id="@+id/MultiVendor_edt_comparable"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_2dp"
                    android:layout_weight="0.5"
                    android:background="@drawable/backgroundg_spinner"
                    android:entries="@array/selection"
                    android:padding="@dimen/pad_5dp"
                    android:paddingStart="@dimen/pad_2dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:orientation="horizontal"
                android:weightSum="2.0">

                <Button
                    android:id="@+id/MultiVendor_unsetfilter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/corner"
                    android:text="@string/Reset_filter"
                    android:textColor="@color/white"


                    />

                <Button
                    android:id="@+id/MultiVendor_setfilter"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="@dimen/pad_5dp"
                    android:layout_weight="1.0"
                    android:background="@drawable/button_style"
                    android:text="@string/Filter"
                    android:textColor="@color/white"

                    />

            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>