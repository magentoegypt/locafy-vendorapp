<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <androidx.constraintlayout.widget.ConstraintLayout xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/verticalguideline"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.38" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_margin="@dimen/pad_5dp"
            android:background="@color/AppTheme"
            android:padding="10dp"
            android:text="@string/new_ticket"
            android:textAlignment="textStart"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/general_info"
            android:layout_width="0dp"
            android:layout_height="@dimen/_45sdp"
            android:layout_marginTop="@dimen/pad_10dp"
            android:background="@color/white"
            android:clickable="false"
            android:gravity="center_vertical"
            android:padding="10dp"
            android:text="@string/general_information"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="@+id/add_new_tkt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title" />

        <TextView
            android:id="@+id/MultiVendor_linebelowvendortag"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/ebebebe"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/general_info" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/add_new_tkt"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:layout_marginEnd="3dp"
            android:background="@drawable/button_save_style"
            android:padding="10dp"
            android:text="@string/save"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="12sp"
            android:visibility="visible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/title" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/customer_name_title"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/customer_name"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/general_info" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/customer_name"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/general_info" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:visibility="gone"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/customer_email"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/customer_name" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/customer_email"
            android:visibility="gone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/customer_name" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/order_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/order"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/customer_email" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/order"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/customer_email" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/subject_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/Subject"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/order" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/subject"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/order" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/department_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/Department"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/subject" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/department"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:backgroundTint="@color/black"
            android:padding="5dp"
            android:text=""
            app:layout_constraintBottom_toBottomOf="@+id/department_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/subject" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/status_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/status"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/department_title" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/status"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:backgroundTint="@color/black"
            android:padding="5dp"
            android:text=""
            app:layout_constraintBottom_toBottomOf="@+id/status_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/department_title" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/priority_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/priority"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/status_title" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/priority"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:backgroundTint="@color/black"
            android:padding="5dp"
            android:text=""
            app:layout_constraintBottom_toBottomOf="@+id/priority_title"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/status_title" />

        <androidx.appcompat.widget.AppCompatTextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_5sdp"
            android:padding="5dp"
            android:text="@string/content"
            app:layout_constraintEnd_toEndOf="@+id/verticalguideline"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/priority_title" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/content"
            android:layout_width="0dp"
            android:layout_height="@dimen/_80sdp"
            android:layout_marginTop="@dimen/_5sdp"
            android:gravity="start"
            android:padding="5dp"
            android:text=""
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
            app:layout_constraintTop_toBottomOf="@+id/priority_title" />


    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>