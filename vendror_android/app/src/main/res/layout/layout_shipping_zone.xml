<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="5dp"
    app:cardUseCompatPadding="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="3dp">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/ship_txt"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:gravity="start|center"
            android:padding="2dp"
            android:text="Price"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/from_txt"
            app:layout_constraintEnd_toStartOf="@id/ship"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/ship"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:background="@drawable/editext_border"
            android:gravity="center"
            android:inputType="number"
            android:maxLines="1"
            android:padding="2dp"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/ship_txt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/ship_txt"
            app:layout_constraintTop_toTopOf="@id/ship_txt" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/from_txt"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:gravity="start|center"
            android:padding="2dp"
            android:text="From"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/to_txt"
            app:layout_constraintEnd_toStartOf="@id/from"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/ship_txt" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/from"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:background="@drawable/editext_border"
            android:gravity="center"
            android:inputType="number"
            android:maxLines="1"
            android:padding="2dp"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/from_txt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/from_txt"
            app:layout_constraintTop_toTopOf="@id/from_txt" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/to_txt"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:gravity="start|center"
            android:padding="2dp"
            android:text="To"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/type_txt"
            app:layout_constraintEnd_toStartOf="@id/to"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/from_txt" />

        <androidx.appcompat.widget.AppCompatEditText
            android:id="@+id/to"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:background="@drawable/editext_border"
            android:gravity="center"
            android:inputType="number"
            android:maxLines="1"
            android:padding="2dp"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/to_txt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/to_txt"
            app:layout_constraintTop_toTopOf="@id/to_txt" />

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/type_txt"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:gravity="start|center"
            android:padding="2dp"
            android:text="@string/Type"
            android:textSize="15sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/remove"
            app:layout_constraintEnd_toStartOf="@id/type"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/to_txt" />

        <androidx.appcompat.widget.AppCompatSpinner
            android:id="@+id/type"
            style="@style/spinner_style"
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_margin="5dp"
            android:entries="@array/shipping_zone_type"
            android:padding="2dp"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="@id/type_txt"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/type_txt"
            app:layout_constraintTop_toTopOf="@id/type_txt" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/remove"
            android:layout_width="wrap_content"
            android:layout_height="25dp"
            android:layout_margin="5dp"
            android:background="@drawable/button_delete_style"
            android:gravity="center"
            android:padding="2dp"
            android:text="Remove"
            android:textColor="@color/white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/type"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="@id/type_txt"
            app:layout_constraintTop_toBottomOf="@id/type_txt" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>