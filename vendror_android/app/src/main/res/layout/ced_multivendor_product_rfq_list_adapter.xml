<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:descendantFocusability="blocksDescendants"
    android:orientation="vertical">

    <androidx.cardview.widget.CardView
        android:id="@+id/item_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="1dp"
        android:background="@color/whitebackground"
        app:cardUseCompatPadding="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/QuoteIncrementId_txt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:text="@string/QuoteIncrementId"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/MultiVendor_CreatedAt"
                app:layout_constraintEnd_toStartOf="@id/QuoteIncrementId"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/QuoteIncrementId"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                app:layout_constraintBottom_toTopOf="@+id/CreatedAt"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/QuoteIncrementId_txt"
                app:layout_constraintTop_toTopOf="parent" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/MultiVendor_CreatedAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:text="@string/CreatedAt"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/MultiVendor_CustomerEmail"
                app:layout_constraintEnd_toStartOf="@id/CreatedAt"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/QuoteIncrementId_txt" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/CreatedAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                app:layout_constraintBottom_toTopOf="@+id/CustomerEmail"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/MultiVendor_CreatedAt"
                app:layout_constraintTop_toBottomOf="@id/QuoteIncrementId" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/MultiVendor_CustomerEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:layout_weight="1.0"
                android:text="@string/CustomerEmail"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toTopOf="@+id/MultiVendor_Status"
                app:layout_constraintEnd_toStartOf="@id/CustomerEmail"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/MultiVendor_CreatedAt" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/CustomerEmail"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:layout_weight="1.0"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                app:layout_constraintBottom_toTopOf="@+id/Status"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/MultiVendor_CustomerEmail"
                app:layout_constraintTop_toBottomOf="@id/CreatedAt" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/MultiVendor_Status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:layout_weight="1.0"
                android:text="@string/Status"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/Status"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/MultiVendor_CustomerEmail" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/Status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/pad_5dp"
                android:layout_weight="1.0"
                android:textColor="@color/black"
                android:textSize="@dimen/txt_13sp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/MultiVendor_Status"
                app:layout_constraintTop_toBottomOf="@id/CustomerEmail" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/MultiVendor_quote_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>