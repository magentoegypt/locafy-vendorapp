<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/pad_10dp"
    android:background="@drawable/editext_border"
    android:orientation="vertical"
    android:id="@+id/main"
    android:padding="10dp">

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/verticalguideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.45" />



    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/Name"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/name"
        android:layout_width="0dp"
        android:editable="false"
        android:enabled="false"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text=""
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toTopOf="parent"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/Type"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/name"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/type"
        android:layout_width="0dp"
        android:editable="false"
        android:enabled="false"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        app:layout_constraintEnd_toEndOf="parent"
        android:text=""
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/name"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/SKU"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/type"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/sku"
        android:layout_width="0dp"
        android:editable="false"
        android:enabled="false"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text=""
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/type"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text="@string/price"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/sku"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/payment_method_value"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_5dp"
        android:background="@drawable/editext_border"
        android:layout_height="wrap_content"
        android:padding="5dp"
        android:text=""
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/verticalguideline"
        app:layout_constraintTop_toBottomOf="@+id/sku"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/edit"
        android:backgroundTint="@color/AppTheme"
        android:textColor="@color/whitebackground"
        android:layout_width="0dp"
        app:layout_constraintWidth_percent="0.5"
        android:layout_marginTop="@dimen/pad_20dp"
        android:layout_height="wrap_content"
        android:text="@string/edit"
        android:layout_marginEnd="10dp"
        app:layout_constraintTop_toBottomOf="@+id/payment_method_value"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>