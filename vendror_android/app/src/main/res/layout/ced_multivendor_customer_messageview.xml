<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="2dp"
    android:background="@color/white"
    app:cardUseCompatPadding="true">

    <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        tools:context="magentoegypt.locafy.addons.messaging.VendorAdmin.Ced_MultiVendor_Admin_MessageView">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/pad_10dp"
            android:layout_marginTop="@dimen/pad_10dp"
            android:text="@string/readmail"
            android:textAllCaps="true"
            android:textColor="@color/AppTheme"
            android:textSize="15dp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:layout_marginTop="@dimen/pad_10dp"
            android:background="@color/black" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginLeft="@dimen/pad_10dp"
            android:layout_marginTop="@dimen/pad_10dp"
            android:layout_marginRight="@dimen/pad_10dp"
            android:gravity="end">

            <Button
                android:id="@+id/MultiVendor_reply"
                android:layout_width="70dp"
                android:layout_height="30dp"
                android:layout_centerVertical="true"
                android:background="@drawable/button_save_style"
                android:text="@string/reply"
                android:textColor="@color/primary_material_light" />
        </RelativeLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/pad_10dp"
            android:layout_marginTop="@dimen/pad_10dp"
            android:layout_marginRight="@dimen/pad_10dp"
            android:gravity="end">

            <TextView
                android:id="@+id/MultiVendor_display_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/Date"
                android:textSize="13dp" />

            <TextView
                android:id="@+id/MultiVendor_display_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/pad_5dp"
                android:layout_toRightOf="@+id/MultiVendor_display_date"
                android:text="Time"
                android:textSize="13dp"
                android:visibility="gone" />

        </RelativeLayout>


        <TextView
            android:id="@+id/MultiVendor_display_subject"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/pad_10dp"
            android:layout_marginTop="@dimen/pad_10dp"
            android:layout_marginRight="@dimen/pad_10dp"
            android:text="subject"
            android:textSize="15dp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/MultiVendor_display_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/pad_10dp"
            android:layout_marginTop="@dimen/pad_5dp"
            android:layout_marginRight="@dimen/pad_10dp"
            android:layout_marginBottom="@dimen/pad_10dp"
            android:text="message"
            android:textSize="13dp" />

    </LinearLayout>
</androidx.cardview.widget.CardView>