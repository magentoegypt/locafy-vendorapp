<RelativeLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:clickable="false"
    android:focusable="false"
    android:focusableInTouchMode="false"
    android:orientation="vertical"
    android:layout_margin="2dp"
    xmlns:android="http://schemas.android.com/apk/res/android">
    <androidx.cardview.widget.CardView
        xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="fill_parent"
        android:layout_height="wrap_content"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="4dp"
        app:cardUseCompatPadding="true"
        android:id="@+id/MultiVendor_view"
        android:background="@color/darker_gray">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_margin="5dp"
                android:weightSum="5">
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_margin="5dp"
                    android:layout_weight="2"
                    >
                    <TextView
                        android:id="@+id/MultiVendor_ID"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/id"
                        android:layout_margin="2dp"/>
                    <TextView
                        android:id="@+id/MultiVendor_productIDtag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/product_id"
                        android:layout_margin="2dp"

                        />
                    <TextView
                        android:id="@+id/MultiVendor_prod_nametag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/product_name"
                        android:layout_margin="2dp"

                        />
                    <TextView
                        android:id="@+id/MultiVendor_producttypetag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/product_type"
                        android:layout_margin="2dp"

                        />
                    <TextView
                        android:id="@+id/MultiVendor_pricetag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/price"
                        android:layout_margin="2dp"
                        />
                    <TextView
                        android:id="@+id/MultiVendor_qtytag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:text="@string/Quantity"
                        android:layout_margin="2dp"

                        />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:layout_weight="1"
                    android:layout_margin="5dp"
                    >
                    <TextView
                        android:layout_width="1dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:layout_gravity="center"
                        android:background="@color/ebebebe"/>
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_margin="5dp"
                    android:layout_weight="2"
                    >
                    <TextView
                        android:id="@+id/MultiVendor_IDtag"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:text="@string/product_id"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />

                    <TextView
                        android:id="@+id/MultiVendor_product_id"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/AppTheme"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:text="@string/product_id"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />

                    <TextView
                        android:id="@+id/MultiVendor_prod_name"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/main_color_gray"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:text="@string/product_name"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />
                    <TextView
                        android:id="@+id/MultiVendor_product_type"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/main_color_gray"
                        android:layout_margin="2dp"
                        android:text="@string/product_price"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />
                    <TextView
                        android:id="@+id/MultiVendor_price"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:text="@string/price"
                        android:textColor="@color/main_color_gray"
                        android:layout_margin="2dp"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />
                    <TextView
                        android:id="@+id/MultiVendor_qty"
                        android:layout_height="wrap_content"
                        android:layout_width="wrap_content"
                        android:textSize="13sp"
                        android:textColor="@color/main_color_gray"
                        android:layout_margin="2dp"
                        android:text="@string/Quantity"
                        android:textStyle="bold"
                        android:maxLines="1"
                        android:ellipsize="end"
                        />

                </LinearLayout></LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="5dp"
                android:weightSum="1"
                android:id="@+id/MultiVendor_editanddellinear">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="35dp"
                    android:id="@+id/MultiVendor_add_auction"
                    android:text="@string/add_auction"
                    android:clickable="true"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:background="@drawable/button_style"
                    android:textColor="@color/white"
                    android:textStyle="bold"
                    />

            </LinearLayout>
        </LinearLayout>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/MultiVendor_picurl"
            android:visibility="gone"/>



    </androidx.cardview.widget.CardView>
</RelativeLayout>
