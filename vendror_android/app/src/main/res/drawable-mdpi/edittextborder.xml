<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <layer-list>
            <item>
                <shape>
                    <gradient android:angle="90" android:endColor="@color/white" android:startColor="#ffffff" android:type="linear" />

                    <stroke android:width="1dp" android:color="#ebebeb" />

                    <corners android:radius="0dp" />

                    <padding
                        android:left="10dp"
                        android:right="10dp" />

                </shape>
            </item>
            <item>
                <bitmap android:gravity="center_vertical|right" android:src="@drawable/downarrow" />
            </item>
        </layer-list>
    </item>

</selector>