<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="MyMaterialTheme.Base">
        <!-- Customize your theme here. -->
        <item name="actionBarStyle">@style/ActionBar</item>
    </style>

    <style name="AppThemeWithActionBar" parent="MyMaterialThemeActionBar.Base">
        <!-- Customize your theme here. -->
        <item name="actionBarStyle">@style/ActionBar</item>
    </style>

    <style name="SpinnerTheme" parent="android:Widget.Spinner">
        <item name="android:background">@drawable/backgroundg_spinner</item>
    </style>

    <style name="MyMaterialTheme.Base" parent="Theme.AppCompat.Light.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBarOverlay">true</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="colorPrimary">@color/AppTheme</item>
        <item name="colorPrimaryDark">@color/status_bar_color</item>
        <item name="colorAccent">@color/status_bar_color</item>

        <item name="android:textColor">@color/black</item>

        <item name="colorControlNormal">@color/secondary_color</item>
        <!-- color of the menu overflow icon -->
        <item name="android:textColorSecondary">@color/white</item>

    </style>

    <style name="MyMaterialThemeActionBar.Base" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowNoTitle">true</item>
        <item name="windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowNoTitle">true</item>
        <item name="windowActionBarOverlay">true</item>
        <item name="android:windowActionBarOverlay">true</item>
        <item name="windowActionModeOverlay">true</item>
        <item name="colorPrimary">@color/AppTheme</item>
        <item name="colorPrimaryDark">@color/status_bar_color</item>
        <item name="colorAccent">@color/status_bar_color</item>
        <item name="colorControlNormal">@color/white</item>
        <item name="android:textColor">@color/black</item>

        <!-- color of the menu overflow icon -->
        <item name="android:textColorSecondary">@color/white</item>

    </style>

    <style name="TransparentProgressDialog" parent="Base.Animation.AppCompat.Dialog">
        <item name="android:windowFrame">@null</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="android:windowTitleStyle">@null</item>
        <item name="android:windowAnimationStyle">@android:style/Animation.Dialog</item>
        <item name="android:windowSoftInputMode">stateUnspecified|adjustPan</item>
        <item name="android:backgroundDimEnabled">false</item>
        <item name="android:background">@android:color/transparent</item>
    </style>
    <!--<style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        &lt;!&ndash; Customize your theme here. &ndash;&gt;
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
    </style>-->
    <style name="ActionBar" parent="@style/Widget.AppCompat.ActionBar">
        <item name="background">@android:color/holo_orange_dark</item>
    </style>

    <!-- <style name="spinner_style">
         <item name="android:divider">#00ff00</item>
         <item name="android:backgroundTint" tools:targetApi="lollipop">@color/AppTheme</item>
         <item name="android:dividerHeight">1dp</item>
         <item name="android:textColor">@color/black</item>
         <item name="android:textColorSecondary">@color/black</item>
     </style>-->

    <style name="spinner_style">
        <item name="android:background">@drawable/edittextborder</item>
        <item name="android:divider">#00ff00</item>
        <item name="android:dividerHeight">1dp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <style name="PauseDialog" parent="@android:style/Theme.Dialog">
        <item name="android:windowTitleStyle">@style/PauseDialogTitle</item>
        <item name="android:color">@color/AppTheme</item>
    </style>

    <style name="PauseDialogTitle" parent="@android:style/TextAppearance.DialogWindowTitle">
        <item name="android:gravity">center_horizontal</item>
        <item name="android:color">@color/AppTheme</item>
        <item name="android:background">@color/AppTheme</item>
    </style>

    <style name="WhiteCheck">
        <item name="android:textColorSecondary">@color/black</item>
        <item name="colorControlNormal">@color/black</item>
    </style>

    <style name="DatePickerButton" parent="ThemeOverlay.MaterialComponents.Dialog">
        <item name="colorAccent">@color/AppTheme</item>                   <!--header background-->
        <item name="android:windowBackground">@color/white</item>     <!--calendar background-->
        <item name="android:colorControlActivated">@color/AppTheme</item> <!--selected day-->
        <item name="android:textColorPrimary">@color/AppTheme</item> <!--days of the month-->
        <item name="android:textColorSecondary">@color/AppTheme</item>    <!--days of the week-->
        <item name="colorPrimary">@color/AppTheme</item>
        <item name="colorPrimaryDark">@color/AppTheme</item>
        <item name="android:textColor">@color/AppTheme</item>
    </style>
</resources>
